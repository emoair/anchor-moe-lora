{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anchor-moe-lora.local/schemas/synthetic-five-role-qonly-diagnostic-record-v1.json",
  "title": "Synthetic five-role Q-only diagnostic record v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_id",
    "role_view_id",
    "task_bundle_id",
    "task_bundle_sha256",
    "task_semantic_sha256",
    "inner_task_id",
    "chain_root_sha256",
    "split",
    "language",
    "stratum",
    "role",
    "canonical_stage",
    "stage_index",
    "view",
    "synthetic_source",
    "input",
    "board_segment_inventory",
    "forbidden_segment_ids",
    "target",
    "route_boundary",
    "ablation",
    "claims",
    "audit"
  ],
  "properties": {
    "schema_version": {
      "const": "anchor.synthetic-five-role-qonly-diagnostic-record.v1"
    },
    "record_id": {
      "type": "string",
      "pattern": "^syn-qonly-record-v1:[0-9a-f]{64}$"
    },
    "role_view_id": {
      "type": "string",
      "pattern": "^syn-qonly-role-view-v1:[0-9a-f]{64}$"
    },
    "task_bundle_id": {
      "type": "string",
      "pattern": "^syn-qonly-bundle-v1:[0-9a-f]{64}$"
    },
    "task_bundle_sha256": {"$ref": "#/$defs/sha256"},
    "task_semantic_sha256": {"$ref": "#/$defs/sha256"},
    "inner_task_id": {
      "type": "string",
      "pattern": "^syn-qonly-task-v1:[0-9a-f]{64}$"
    },
    "chain_root_sha256": {"$ref": "#/$defs/sha256"},
    "split": {"enum": ["train", "eval_proxy"]},
    "language": {"enum": ["en", "zh-CN"]},
    "stratum": {"$ref": "#/$defs/stratum"},
    "role": {"$ref": "#/$defs/role"},
    "canonical_stage": {"$ref": "#/$defs/canonical_stage"},
    "stage_index": {"type": "integer", "minimum": 0, "maximum": 4},
    "view": {"const": "concise_rationale_plus_json"},
    "synthetic_source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "bundle_key",
        "archetype",
        "stratum",
        "closed_grammar_id",
        "closed_grammar_sha256",
        "generation_seed_id",
        "generation_seed_sha256",
        "generator_config_sha256",
        "generator_implementation_sha256",
        "base_security_implementation_sha256"
      ],
      "properties": {
        "kind": {"const": "closed_grammar_synthetic_no_external_body"},
        "bundle_key": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$",
          "minLength": 8,
          "maxLength": 128
        },
        "archetype": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$",
          "minLength": 3,
          "maxLength": 96
        },
        "stratum": {"$ref": "#/$defs/stratum"},
        "closed_grammar_id": {
          "const": "anchor.synthetic-five-role-qonly-closed-grammar.v1"
        },
        "closed_grammar_sha256": {"$ref": "#/$defs/sha256"},
        "generation_seed_id": {
          "const": "anchor.synthetic-five-role-qonly-diagnostic.seed.v1"
        },
        "generation_seed_sha256": {"$ref": "#/$defs/sha256"},
        "generator_config_sha256": {"$ref": "#/$defs/sha256"},
        "generator_implementation_sha256": {"$ref": "#/$defs/sha256"},
        "base_security_implementation_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_text",
        "constraints",
        "acceptance_hints",
        "role_instruction",
        "allowed_context_segments",
        "materialized_prompt",
        "input_sha256"
      ],
      "properties": {
        "task_text": {"type": "string", "minLength": 16, "maxLength": 2048},
        "constraints": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": {"type": "string", "minLength": 4, "maxLength": 512}
        },
        "acceptance_hints": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": {"type": "string", "minLength": 4, "maxLength": 512}
        },
        "role_instruction": {
          "type": "string",
          "minLength": 12,
          "maxLength": 1024
        },
        "allowed_context_segments": {
          "type": "array",
          "maxItems": 4,
          "items": {"$ref": "#/$defs/visible_segment"}
        },
        "materialized_prompt": {
          "type": "string",
          "minLength": 64,
          "maxLength": 32768
        },
        "input_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "board_segment_inventory": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {"$ref": "#/$defs/segment_inventory_entry"}
    },
    "forbidden_segment_ids": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/segment_id"}
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonical_routing_json",
        "canonical_json_sha256",
        "concise_rationale_summary",
        "serialized_assistant_output",
        "output_sha256"
      ],
      "properties": {
        "canonical_routing_json": {"$ref": "#/$defs/route"},
        "canonical_json_sha256": {"$ref": "#/$defs/sha256"},
        "concise_rationale_summary": {
          "type": "string",
          "minLength": 8,
          "maxLength": 1024,
          "pattern": "^[^\\r\\n]+$"
        },
        "serialized_assistant_output": {
          "type": "string",
          "minLength": 48,
          "maxLength": 32768,
          "pattern": "^[^\\r\\n]+\\n\\{[^\\r\\n]*\\}$"
        },
        "output_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "route_boundary": {
      "const": {
        "semantics": "explicit_two_request_commit",
        "activation_semantics": "next_request_input_activation_only",
        "committed_scaffold_reencode_required": true,
        "planner_request1_private_kv_reused": false
      }
    },
    "ablation": {
      "const": {
        "arm_neutral": true,
        "assignment_location": "diagnostic_run_manifest_only",
        "identical_inventory_required": true,
        "row_duplicated_for_controls": false,
        "serialized_into_prompt_or_target": false
      }
    },
    "claims": {
      "const": {
        "diagnostic_only": true,
        "formal": false,
        "training_authorized": false,
        "quality_validated": false,
        "proxy_signal_only": true,
        "physical_kv_reuse_claimed": false,
        "numeric_equivalence_claimed": false
      }
    },
    "audit": {
      "const": {
        "protected_body_reads": 0,
        "provider_requests": 0,
        "network_requests": 0,
        "model_loads": 0,
        "gpu_requests": 0,
        "real_tool_executions": 0
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"role": {"const": "planner"}}},
      "then": {
        "properties": {
          "canonical_stage": {"const": "planner"},
          "stage_index": {"const": 0}
        }
      }
    },
    {
      "if": {"properties": {"role": {"const": "tool_policy"}}},
      "then": {
        "properties": {
          "canonical_stage": {"const": "tool_policy"},
          "stage_index": {"const": 1}
        }
      }
    },
    {
      "if": {"properties": {"role": {"const": "frontend_gen"}}},
      "then": {
        "properties": {
          "canonical_stage": {"const": "domain_builder"},
          "stage_index": {"const": 2}
        }
      }
    },
    {
      "if": {"properties": {"role": {"const": "frontend_review"}}},
      "then": {
        "properties": {
          "canonical_stage": {"const": "domain_review"},
          "stage_index": {"const": 3}
        }
      }
    },
    {
      "if": {"properties": {"role": {"const": "security_gate"}}},
      "then": {
        "properties": {
          "canonical_stage": {"const": "security"},
          "stage_index": {"const": 4}
        }
      }
    }
  ],
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "role": {
      "enum": ["planner", "tool_policy", "frontend_gen", "frontend_review", "security_gate"]
    },
    "canonical_stage": {
      "enum": ["planner", "tool_policy", "domain_builder", "domain_review", "security"]
    },
    "stratum": {
      "enum": [
        "prefix_evidence_selection",
        "prefix_evidence_plus_structured_private_writeback",
        "conflicting_allowed_evidence_resolution",
        "tool_result_commit_then_expert_private_tail",
        "ordered_long_prefix_retrieval"
      ]
    },
    "segment_id": {
      "type": "string",
      "pattern": "^syn-qonly-segment-v1:[0-9a-f]{64}$"
    },
    "segment_ref": {"type": "string", "pattern": "^S[0-4]$"},
    "visible_segment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "segment_ref",
        "role",
        "canonical_stage",
        "stage_index",
        "committed_summary"
      ],
      "properties": {
        "segment_ref": {"$ref": "#/$defs/segment_ref"},
        "role": {"$ref": "#/$defs/role"},
        "canonical_stage": {"$ref": "#/$defs/canonical_stage"},
        "stage_index": {"type": "integer", "minimum": 0, "maximum": 3},
        "committed_summary": {"type": "string", "minLength": 8, "maxLength": 1024}
      }
    },
    "segment_inventory_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "segment_id",
        "segment_ref",
        "role",
        "canonical_stage",
        "stage_index",
        "content_sha256",
        "visibility"
      ],
      "properties": {
        "segment_id": {"$ref": "#/$defs/segment_id"},
        "segment_ref": {"$ref": "#/$defs/segment_ref"},
        "role": {"$ref": "#/$defs/role"},
        "canonical_stage": {"$ref": "#/$defs/canonical_stage"},
        "stage_index": {"type": "integer", "minimum": 0, "maximum": 4},
        "content_sha256": {"$ref": "#/$defs/sha256"},
        "visibility": {
          "enum": ["previous_committed", "current_target", "future_target"]
        }
      }
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "canonical_stage",
        "expert",
        "goal",
        "constraints",
        "evidence_intent",
        "allowed_segment_refs",
        "evidence_segment_refs",
        "tool_plan",
        "acceptance_criteria"
      ],
      "properties": {
        "role": {"$ref": "#/$defs/role"},
        "canonical_stage": {"$ref": "#/$defs/canonical_stage"},
        "expert": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
        "goal": {"type": "string", "minLength": 8, "maxLength": 1024},
        "constraints": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": {"type": "string", "minLength": 4, "maxLength": 512}
        },
        "evidence_intent": {
          "type": "string",
          "minLength": 8,
          "maxLength": 1024
        },
        "allowed_segment_refs": {
          "type": "array",
          "maxItems": 4,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/segment_ref"}
        },
        "evidence_segment_refs": {
          "type": "array",
          "maxItems": 4,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/segment_ref"}
        },
        "tool_plan": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["action", "mode"],
            "properties": {
              "action": {
                "type": "string",
                "minLength": 3,
                "maxLength": 512,
                "pattern": "^[^\\r\\n]+$"
              },
              "mode": {"const": "harmless_synthetic_fixture_trace"}
            }
          }
        },
        "acceptance_criteria": {
          "type": "array",
          "minItems": 2,
          "maxItems": 4,
          "items": {"type": "string", "minLength": 4, "maxLength": 512}
        }
      }
    }
  }
}
