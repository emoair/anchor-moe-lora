{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/emoair/anchor-moe-lora/schemas/generic-train-release-lock-v2.json",
  "title": "Generic train release lock",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "status", "bindings", "fixed_files", "consumer",
    "hierarchical_task_kv",
    "split_group_key", "task_id_cross_binding_key", "required_roles",
    "provenance_location", "calibration_is_heldout", "heldout_content_read",
    "heldout_content_emitted", "canonical_gold_written", "provider_requests",
    "claim_scope"
  ],
  "properties": {
    "schema_version": {"const": "anchor.generic-train-release-lock.v2"},
    "status": {"const": "ready"},
    "bindings": {
      "type": "object", "additionalProperties": false,
      "required": [
        "projector_manifest_sha256", "projector_manifest_schema_sha256",
        "projector_sidecar_schema_sha256",
        "projector_segment_plan_schema_sha256",
        "source_disjoint_manifest_sha256",
        "generic_execution_contract_sha256", "consumer_contract_sha256",
        "execution_lock_sha256", "attestation_sha256",
        "coordinator_config_sha256", "source_bank_manifest_sha256"
      ],
      "properties": {
        "projector_manifest_sha256": {"$ref": "#/$defs/sha256"},
        "projector_manifest_schema_sha256": {"$ref": "#/$defs/sha256"},
        "projector_sidecar_schema_sha256": {"$ref": "#/$defs/sha256"},
        "projector_segment_plan_schema_sha256": {"$ref": "#/$defs/sha256"},
        "source_disjoint_manifest_sha256": {"$ref": "#/$defs/sha256"},
        "generic_execution_contract_sha256": {"$ref": "#/$defs/sha256"},
        "consumer_contract_sha256": {"$ref": "#/$defs/sha256"},
        "execution_lock_sha256": {"$ref": "#/$defs/sha256"},
        "attestation_sha256": {"$ref": "#/$defs/sha256"},
        "coordinator_config_sha256": {"$ref": "#/$defs/sha256"},
        "source_bank_manifest_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "fixed_files": {
      "type": "array", "minItems": 3, "maxItems": 3,
      "prefixItems": [
        {"$ref": "#/$defs/train_clean"},
        {"$ref": "#/$defs/train_noisy"},
        {"$ref": "#/$defs/calibration_clean"}
      ],
      "items": false
    },
    "consumer": {
      "type": "object", "additionalProperties": false,
      "required": ["consumer_id", "consumer_version", "implementation_files", "launch_entrypoint"],
      "properties": {
        "consumer_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{0,127}$"},
        "consumer_version": {"type": "string", "minLength": 1},
        "implementation_files": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/path_hash"}},
        "launch_entrypoint": {"$ref": "#/$defs/path_hash"}
      }
    },
    "hierarchical_task_kv": {"$ref": "#/$defs/hierarchical_task_kv"},
    "split_group_key": {"const": "task_bundle_sha256"},
    "task_id_cross_binding_key": {"const": "training_record.task_board.task_id"},
    "required_roles": {
      "const": ["planner", "tool_policy", "frontend_gen", "frontend_review", "security_gate"]
    },
    "provenance_location": {"const": "outer_sidecar"},
    "calibration_is_heldout": {"const": false},
    "heldout_content_read": {"const": false},
    "heldout_content_emitted": {"const": false},
    "canonical_gold_written": {"const": false},
    "provider_requests": {"const": 0},
    "claim_scope": {"const": "research_proxy_only"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "hierarchical_task_kv": {
      "type": "object", "additionalProperties": false,
      "required": [
        "segment_plan_schema_version", "segment_plan_schema_sha256",
        "segment_plan_location", "architecture", "execution_mode",
        "materialization", "tensors_emitted", "kv_payloads_emitted",
        "shared_prefix_membership", "ordered_prefix_chain",
        "independent_segment_concatenation_allowed", "exact_reuse_scope",
        "shared_then_mask_allowed", "forbidden_current_future_preinsert_allowed",
        "cache_identity_required_exact_match_fields",
        "cache_identity_mismatch_result", "cache_identity_unknown_result",
        "target_delta_initial_cache_scope", "target_delta_promotion_requires",
        "target_delta_promoted_cache_scope", "current_target_segment_emitted",
        "q_specialization_alone_sufficient_for_exact_reuse",
        "naive_in_stack_q_lora_exact_reuse_allowed",
        "full_generation_kv_shared_claimed", "token_level_moe_claimed"
      ],
      "properties": {
        "segment_plan_schema_version": {
          "const": "anchor.hierarchical-task-kv-segment-plan.v1"
        },
        "segment_plan_schema_sha256": {"$ref": "#/$defs/sha256"},
        "segment_plan_location": {"const": "outer_sidecar.segment_plan"},
        "architecture": {"const": "hierarchical_task_kv"},
        "execution_mode": {
          "const": "decoupled_frozen_prefix_producer_required"
        },
        "materialization": {"const": "metadata_only_no_tensor_or_kv"},
        "tensors_emitted": {"const": false},
        "kv_payloads_emitted": {"const": false},
        "shared_prefix_membership": {
          "const": "strict_all_five_role_visibility_intersection"
        },
        "ordered_prefix_chain": {"const": true},
        "independent_segment_concatenation_allowed": {"const": false},
        "exact_reuse_scope": {
          "const": "identical_ordered_prefix_lineage_only"
        },
        "shared_then_mask_allowed": {"const": false},
        "forbidden_current_future_preinsert_allowed": {"const": false},
        "cache_identity_required_exact_match_fields": {
          "type": "array",
          "prefixItems": [
            {"const": "model_architecture_sha256"},
            {"const": "tokenizer_sha256"},
            {"const": "token_order_sha256"},
            {"const": "position_ids_sha256"},
            {"const": "rope_config_sha256"},
            {"const": "kv_producing_weights_sha256"},
            {"const": "prefix_lineage_sha256"}
          ],
          "items": false, "minItems": 7, "maxItems": 7
        },
        "cache_identity_mismatch_result": {"const": "cache_incompatible"},
        "cache_identity_unknown_result": {"const": "cache_incompatible"},
        "target_delta_initial_cache_scope": {"const": "expert_private_delta"},
        "target_delta_promotion_requires": {
          "const": "explicit_committed_and_causally_visible_downstream"
        },
        "target_delta_promoted_cache_scope": {
          "const": "downstream_task_shared_immutable"
        },
        "current_target_segment_emitted": {"const": false},
        "q_specialization_alone_sufficient_for_exact_reuse": {"const": false},
        "naive_in_stack_q_lora_exact_reuse_allowed": {"const": false},
        "full_generation_kv_shared_claimed": {"const": false},
        "token_level_moe_claimed": {"const": false}
      }
    },
    "relative_path": {"type": "string", "minLength": 1, "pattern": "^(?![A-Za-z]:)(?![/\\\\])(?!.*(?:^|[/\\\\])\\.\\.(?:[/\\\\]|$)).+$"},
    "path_hash": {
      "type": "object", "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {"path": {"$ref": "#/$defs/relative_path"}, "sha256": {"$ref": "#/$defs/sha256"}}
    },
    "file": {
      "type": "object", "additionalProperties": false,
      "required": ["path", "sha256", "bytes", "records", "split", "variant"],
      "properties": {
        "path": {"$ref": "#/$defs/relative_path"}, "sha256": {"$ref": "#/$defs/sha256"},
        "bytes": {"type": "integer", "minimum": 1}, "records": {"type": "integer", "minimum": 1},
        "split": {"enum": ["train", "calibration"]}, "variant": {"enum": ["clean", "noisy"]}
      }
    },
    "train_clean": {"allOf": [{"$ref": "#/$defs/file"}, {"properties": {"path": {"const": "train/clean.jsonl"}, "split": {"const": "train"}, "variant": {"const": "clean"}}}]},
    "train_noisy": {"allOf": [{"$ref": "#/$defs/file"}, {"properties": {"path": {"const": "train/noisy.jsonl"}, "split": {"const": "train"}, "variant": {"const": "noisy"}}}]},
    "calibration_clean": {"allOf": [{"$ref": "#/$defs/file"}, {"properties": {"path": {"const": "calibration/clean.jsonl"}, "split": {"const": "calibration"}, "variant": {"const": "clean"}}}]}
  }
}
