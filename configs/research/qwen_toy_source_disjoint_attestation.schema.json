    "read_base": {
      "type": "object",
      "required": [
        "role",
        "path",
        "bytes",
        "sha256"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/safe_relative_path"
        },
        "bytes": {
          "type": "integer",
          "minimum": 1
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "generator_read": {
      "allOf": [
        {
          "$ref": "#/$defs/read_base"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "role",
            "path",
            "bytes",
            "sha256"
          ],
          "properties": {
            "role": {
              "const": "generator"
            },
            "path": {
              "$ref": "#/$defs/safe_relative_path"
            },
            "bytes": {
              "type": "integer",
              "minimum": 1
            },
            "sha256": {
              "$ref": "#/$defs/sha256"
            }
          }
        }
      ]
    },
    "config_read": {
      "allOf": [
        {
          "$ref": "#/$defs/read_base"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "role",
            "path",
            "bytes",
            "sha256"
          ],
          "properties": {
            "role": {
              "const": "generator_config"
