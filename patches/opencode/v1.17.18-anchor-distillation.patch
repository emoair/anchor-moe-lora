diff --git a/packages/opencode/src/anchor/sandbox.ts b/packages/opencode/src/anchor/sandbox.ts
new file mode 100644
index 0000000..1fbb7a9
--- /dev/null
+++ b/packages/opencode/src/anchor/sandbox.ts
@@ -0,0 +1,654 @@
+import { randomUUID } from "node:crypto"
+import { mkdir, rm } from "node:fs/promises"
+import path from "node:path"
+import { Process } from "@/util/process"
+import type { Result, RunOptions } from "@/util/process"
+
+export type AnchorHost = "windows-wsl" | "linux"
+export type AnchorSupervisor = "direct" | "wsl-root-systemd"
+
+/** Official Node 22 bookworm-slim linux/amd64 manifest digest, refreshed 2026-07-13. */
+export const DEFAULT_ANCHOR_IMAGE =
+  "docker.io/library/node@sha256:a149cd71dccd68704a07d4e4ca3e610c27301852b0f556865cfdb6e2856f8bed"
+
+export interface AnchorSandboxSpec {
+  workspace: string
+  config: string
+  runID: string
+  wslDistro?: string
+  image?: string
+  linuxExecutable?: string
+  memory?: string
+  cpus?: number
+  pids?: number
+  timeout?: number
+  supervisor?: AnchorSupervisor
+}
+
+export interface AnchorContainerPaths {
+  workspace: string
+  config: string
+  state: string
+  linuxExecutable?: string
+}
+
+export interface AnchorLimits {
+  memory: string
+  cpus: number
+  pids: number
+  timeout: number
+}
+
+export interface CommandRunner {
+  run(command: string[], options?: RunOptions): Promise<Result>
+}
+
+export class AnchorSandboxError extends Error {
+  constructor(readonly code: string) {
+    super(code)
+    this.name = "AnchorSandboxError"
+  }
+}
+
+const RUN_ID = /^[A-Za-z0-9][A-Za-z0-9_-]{0,79}$/
+const MEMORY = /^\d+(?:\.\d+)?(?:[KMGTP]i?B?|B)?$/i
+const systemRunner: CommandRunner = { run: Process.run }
+
+export function validateRunID(value: string): string {
+  if (!RUN_ID.test(value)) throw new AnchorSandboxError("anchor_run_id_invalid")
+  return value
+}
+
+export function resolveAnchorHost(platform = process.platform): AnchorHost {
+  if (platform === "win32") return "windows-wsl"
+  if (platform === "linux") return "linux"
+  throw new AnchorSandboxError("anchor_host_platform_unsupported")
+}
+
+export function resolveSupervisor(value: AnchorSupervisor | undefined, host: AnchorHost): AnchorSupervisor {
+  const supervisor = value ?? (host === "windows-wsl" ? "wsl-root-systemd" : "direct")
+  if (supervisor === "wsl-root-systemd" && host !== "windows-wsl") {
+    throw new AnchorSandboxError("anchor_supervisor_host_mismatch")
+  }
+  return supervisor
+}
+
+function absolute(value: string, code: string) {
+  if (!path.isAbsolute(value)) throw new AnchorSandboxError(code)
+  return path.normalize(value)
+}
+
+function positiveInteger(value: number | undefined, fallback: number, code: string) {
+  const normalized = value ?? fallback
+  if (!Number.isSafeInteger(normalized) || normalized <= 0) throw new AnchorSandboxError(code)
+  return normalized
+}
+
+export function resolveLimits(input: Pick<AnchorSandboxSpec, "memory" | "cpus" | "pids" | "timeout">): AnchorLimits {
+  const memory = input.memory ?? "4G"
+  if (!MEMORY.test(memory)) throw new AnchorSandboxError("anchor_memory_invalid")
+  const cpus = input.cpus ?? 2
+  if (!Number.isFinite(cpus) || cpus <= 0) throw new AnchorSandboxError("anchor_cpus_invalid")
+  return {
+    memory,
+    cpus,
+    pids: positiveInteger(input.pids, 256, "anchor_pids_invalid"),
+    timeout: positiveInteger(input.timeout, 900, "anchor_timeout_invalid"),
+  }
+}
+
+export function resolveSandboxPaths(input: Pick<AnchorSandboxSpec, "workspace" | "config" | "runID">) {
+  const workspace = absolute(input.workspace, "anchor_workspace_not_absolute")
+  const config = absolute(input.config, "anchor_config_not_absolute")
+  const runID = validateRunID(input.runID)
+  return {
+    workspace,
+    config,
+    state: path.join(workspace, ".anchor", "sandbox", runID),
+    runID,
+  }
+}
+
+export function resolveImage(input: Pick<AnchorSandboxSpec, "image">, environment: NodeJS.ProcessEnv = process.env) {
+  const image = input.image ?? environment.ANCHOR_PODMAN_IMAGE ?? DEFAULT_ANCHOR_IMAGE
+  if (!image.trim()) throw new AnchorSandboxError("anchor_image_missing")
+  return image
+}
+
+export function scrubHostEnvironment(input: NodeJS.ProcessEnv = process.env): NodeJS.ProcessEnv {
+  const blocked = new Set([
+    "KIMI_CODE_API_KEY",
+    "OPENCODE_CONFIG_CONTENT",
+    "CONTAINER_HOST",
+    "DOCKER_HOST",
+    "PODMAN_HOST",
+    "WSLENV",
+  ])
+  return Object.fromEntries(Object.entries(input).filter(([key]) => !blocked.has(key.toUpperCase())))
+}
+
+export function containerName(runID: string) {
+  return `anchor-${validateRunID(runID)}`
+}
+
+/** Deterministic so `anchor cleanup --run-id` can remove a secret left by a crashed task. */
+export function secretName(runID: string) {
+  return `anchor-key-${validateRunID(runID)}`
+}
+
+/** Name of the one-child environment variable used to feed `podman secret create --env`. */
+export function secretEnvironmentName(runID: string, nonce = randomUUID()) {
+  const task = validateRunID(runID).replaceAll("-", "_").toUpperCase()
+  return `ANCHOR_SECRET_${task}_${nonce.replaceAll("-", "").toUpperCase()}`.slice(0, 180)
+}
+
+export function systemdUnitName(runID: string, nonce = randomUUID()) {
+  return `anchor-${validateRunID(runID)}-${nonce.replaceAll("-", "")}`.slice(0, 120)
+}
+
+/**
+ * Keep the provider credential in a one-child environment only.  WSLENV `/u`
+ * is the documented Windows-to-WSL direction, so the value reaches rootful
+ * Podman without appearing in argv, a config file, or a log payload.
+ */
+export function buildSecretEnvironment(input: {
+  host: AnchorHost
+  environment: NodeJS.ProcessEnv
+  variable: string
+  value: string
+}): NodeJS.ProcessEnv {
+  const environment = { ...input.environment, [input.variable]: input.value }
+  if (input.host !== "windows-wsl") return environment
+
+  environment.WSLENV = `${input.variable}/u`
+  return environment
+}
+
+export function buildSecretCreateArgs(secret: string, variable: string) {
+  return ["secret", "create", "--env=true", secret, variable]
+}
+
+export function buildHostExecCommand(input: {
+  host: AnchorHost
+  distro?: string
+  root?: boolean
+  command: string[]
+}) {
+  if (input.host === "linux") return input.command
+  if (!input.distro?.trim()) throw new AnchorSandboxError("anchor_wsl_distro_missing")
+  return [
+    "wsl.exe",
+    "--distribution",
+    input.distro,
+    ...(input.root ? ["--user", "root"] : []),
+    "--exec",
+    ...input.command,
+  ]
+}
+
+export function buildPodmanCommand(input: {
+  host: AnchorHost
+  distro?: string
+  supervisor: AnchorSupervisor
+  operation: "run" | "manage"
+  podmanArgs: string[]
+  limits: AnchorLimits
+  unit?: string
+}) {
+  if (input.host === "linux") return ["podman", ...input.podmanArgs]
+  if (input.supervisor === "direct") {
+    return buildHostExecCommand({ host: input.host, distro: input.distro, command: ["podman", ...input.podmanArgs] })
+  }
+  if (input.operation === "manage") {
+    return buildHostExecCommand({
+      host: input.host,
+      distro: input.distro,
+      root: true,
+      command: ["podman", ...input.podmanArgs],
+    })
+  }
+  const unit = input.unit ?? systemdUnitName("anchor")
+  return buildHostExecCommand({
+    host: input.host,
+    distro: input.distro,
+    root: true,
+    command: [
+      "systemd-run",
+      "--quiet",
+      "--wait",
+      "--collect",
+      "--pipe",
+      `--unit=${unit}`,
+      "-p",
+      `MemoryMax=${input.limits.memory}`,
+      "-p",
+      `CPUQuota=${input.limits.cpus * 100}%`,
+      "-p",
+      `TasksMax=${input.limits.pids}`,
+      "-p",
+      `RuntimeMaxSec=${input.limits.timeout}s`,
+      "--",
+      "podman",
+      ...input.podmanArgs,
+    ],
+  })
+}
+
+function containerBaseArgs(input: {
+  runID: string
+  paths: AnchorContainerPaths
+  limits: AnchorLimits
+  rootful: boolean
+}) {
+  const args = [
+    "run",
+    "--rm",
+    "--name",
+    containerName(input.runID),
+    "--cap-drop=ALL",
+    "--security-opt=no-new-privileges",
+    "--read-only",
+    "--tmpfs",
+    "/tmp:rw,noexec,nosuid,size=256m",
+    "--workdir",
+    "/workspace",
+    "--mount",
+    `type=bind,src=${input.paths.workspace},dst=/workspace,rw`,
+    "--mount",
+    `type=bind,src=${input.paths.state},dst=/anchor/state,rw`,
+    "--mount",
+    `type=bind,src=${input.paths.config},dst=/anchor/config/opencode.json,ro`,
+    "--env",
+    "OPENCODE_CONFIG=/anchor/config/opencode.json",
+    "--env",
+    "OPENCODE_CONFIG_DIR=/anchor/state/config",
+    "--env",
+    "OPENCODE_DISABLE_PROJECT_CONFIG=true",
+    "--env",
+    "OPENCODE_DISABLE_DEFAULT_PLUGINS=true",
+    "--env",
+    "OPENCODE_DISABLE_LSP_DOWNLOAD=true",
+    "--env",
+    "OPENCODE_DISABLE_MODELS_FETCH=true",
+    "--env",
+    "OPENCODE_AUTO_SHARE=false",
+    "--env",
+    "HOME=/anchor/state/home",
+    "--env",
+    "XDG_CONFIG_HOME=/anchor/state/config",
+    "--env",
+    "XDG_DATA_HOME=/anchor/state/data",
+    "--env",
+    "XDG_CACHE_HOME=/anchor/state/cache",
+  ]
+  if (input.rootful) {
+    // WSL's older rootful Podman cannot set the requested resource flags with cgroups enabled.
+    args.push("--cgroups=disabled")
+  } else {
+    args.push(
+      "--userns=keep-id",
+      "--memory",
+      input.limits.memory,
+      "--cpus",
+      String(input.limits.cpus),
+      "--pids-limit",
+      String(input.limits.pids),
+      "--network",
+      "slirp4netns",
+    )
+  }
+  if (input.paths.linuxExecutable) {
+    args.push("--mount", `type=bind,src=${input.paths.linuxExecutable},dst=/anchor/bin/opencode,ro`)
+  }
+  return args
+}
+
+export function buildContainerRunArgs(input: {
+  image: string
+  runID: string
+  paths: AnchorContainerPaths
+  limits: AnchorLimits
+  rootful: boolean
+  secret: string
+  opencodeArgs: string[]
+}) {
+  const executable = input.paths.linuxExecutable ? "/anchor/bin/opencode" : "opencode"
+  // Rootful Podman in this WSL host cannot create its default CNI bridge because
+  // its nftables/iptables NAT backend is incompatible.  Use the userspace
+  // network only for the task run; export remains explicitly offline below.
+  const network = input.rootful ? ["--network", "slirp4netns"] : []
+  return [
+    ...containerBaseArgs(input),
+    ...network,
+    "--secret",
+    `source=${input.secret},target=anchor_api_key,type=mount,mode=0400`,
+    "--entrypoint",
+    "/bin/sh",
+    input.image,
+    "-c",
+    'export KIMI_CODE_API_KEY="$(cat \"$1\")"; shift; exec "$@"',
+    "anchor-entrypoint",
+    "/run/secrets/anchor_api_key",
+    executable,
+    ...input.opencodeArgs,
+  ]
+}
+
+export function buildContainerExportArgs(input: {
+  image: string
+  runID: string
+  paths: AnchorContainerPaths
+  limits: AnchorLimits
+  rootful: boolean
+  sessionID: string
+}) {
+  const executable = input.paths.linuxExecutable ? "/anchor/bin/opencode" : "opencode"
+  return [
+    ...containerBaseArgs(input),
+    "--network",
+    "none",
+    "--entrypoint",
+    executable,
+    input.image,
+    "export",
+    input.sessionID,
+  ]
+}
+
+async function toWslPath(
+  runner: CommandRunner,
+  distro: string | undefined,
+  hostPath: string,
+  environment: NodeJS.ProcessEnv,
+) {
+  const result = await runner.run(
+    buildHostExecCommand({
+      host: "windows-wsl",
+      distro,
+      command: ["wslpath", "-a", "-u", hostPath],
+    }),
+    { env: environment, envMode: "replace", nothrow: true },
+  )
+  const converted = result.stdout.toString().trim()
+  if (result.code !== 0 || !converted) throw new AnchorSandboxError("anchor_wslpath_failed")
+  return converted
+}
+
+async function resolveContainerPaths(input: {
+  spec: AnchorSandboxSpec
+  host: AnchorHost
+  runner: CommandRunner
+  environment: NodeJS.ProcessEnv
+}) {
+  const local = resolveSandboxPaths(input.spec)
+  const linuxExecutable = input.spec.linuxExecutable
+    ? absolute(input.spec.linuxExecutable, "anchor_linux_executable_not_absolute")
+    : undefined
+  await mkdir(local.state, { recursive: true })
+  if (input.host === "linux") {
+    return {
+      local,
+      container: { ...local, linuxExecutable } satisfies AnchorContainerPaths,
+    }
+  }
+  const converted = await Promise.all([
+    toWslPath(input.runner, input.spec.wslDistro, local.workspace, input.environment),
+    toWslPath(input.runner, input.spec.wslDistro, local.config, input.environment),
+    toWslPath(input.runner, input.spec.wslDistro, local.state, input.environment),
+    linuxExecutable ? toWslPath(input.runner, input.spec.wslDistro, linuxExecutable, input.environment) : Promise.resolve(undefined),
+  ])
+  return {
+    local,
+    container: {
+      workspace: converted[0],
+      config: converted[1],
+      state: converted[2],
+      linuxExecutable: converted[3],
+    } satisfies AnchorContainerPaths,
+  }
+}
+
+async function removeContainer(input: {
+  spec: Pick<AnchorSandboxSpec, "runID" | "wslDistro" | "supervisor">
+  host: AnchorHost
+  supervisor: AnchorSupervisor
+  limits: AnchorLimits
+  runner: CommandRunner
+  environment: NodeJS.ProcessEnv
+}) {
+  const result = await input.runner.run(
+    buildPodmanCommand({
+      host: input.host,
+      distro: input.spec.wslDistro,
+      supervisor: input.supervisor,
+      operation: "manage",
+      podmanArgs: ["rm", "--force", "--ignore", containerName(input.spec.runID)],
+      limits: input.limits,
+    }),
+    { env: input.environment, envMode: "replace", nothrow: true },
+  )
+  if (result.code !== 0) throw new AnchorSandboxError("anchor_container_remove_failed")
+}
+
+async function removeSecret(input: {
+  spec: Pick<AnchorSandboxSpec, "runID" | "wslDistro" | "supervisor">
+  host: AnchorHost
+  supervisor: AnchorSupervisor
+  limits: AnchorLimits
+  secret: string
+  runner: CommandRunner
+  environment: NodeJS.ProcessEnv
+}) {
+  const listed = await input.runner.run(
+    buildPodmanCommand({
+      host: input.host,
+      distro: input.spec.wslDistro,
+      supervisor: input.supervisor,
+      operation: "manage",
+      podmanArgs: ["secret", "ls", "--format", "{{.Name}}"],
+      limits: input.limits,
+    }),
+    { env: input.environment, envMode: "replace", nothrow: true },
+  )
+  if (listed.code !== 0) throw new AnchorSandboxError("anchor_secret_list_failed")
+  const secret = input.secret
+  if (!listed.stdout.toString().split(/\r?\n/).includes(secret)) return
+
+  const removed = await input.runner.run(
+    buildPodmanCommand({
+      host: input.host,
+      distro: input.spec.wslDistro,
+      supervisor: input.supervisor,
+      operation: "manage",
+      podmanArgs: ["secret", "rm", secret],
+      limits: input.limits,
+    }),
+    { env: input.environment, envMode: "replace", nothrow: true },
+  )
+  if (removed.code !== 0) throw new AnchorSandboxError("anchor_secret_remove_failed")
+}
+
+async function cleanupRuntimeResources(input: {
+  spec: Pick<AnchorSandboxSpec, "runID" | "wslDistro" | "supervisor">
+  host: AnchorHost
+  supervisor: AnchorSupervisor
+  limits: AnchorLimits
+  secret: string
+  runner: CommandRunner
+  environment: NodeJS.ProcessEnv
+}) {
+  const errors: unknown[] = []
+  try {
+    await removeContainer(input)
+  } catch (error) {
+    errors.push(error)
+  }
+  try {
+    await removeSecret(input)
+  } catch (error) {
+    errors.push(error)
+  }
+  if (errors.length === 1) throw errors[0]
+  if (errors.length > 1) throw new AggregateError(errors, "anchor_runtime_cleanup_failed")
+}
+
+async function withHostTimeout<T>(timeout: number, fn: (abort: AbortSignal) => Promise<T>) {
+  const controller = new AbortController()
+  const timer = setTimeout(() => controller.abort(), timeout * 1000)
+  try {
+    return await fn(controller.signal)
+  } finally {
+    clearTimeout(timer)
+  }
+}
+
+export async function runSandboxed(
+  spec: AnchorSandboxSpec,
+  opencodeArgs: string[],
+  options: { runner?: CommandRunner; apiKey?: string; platform?: NodeJS.Platform } = {},
+) {
+  const runner = options.runner ?? systemRunner
+  const apiKey = options.apiKey ?? process.env.KIMI_CODE_API_KEY
+  if (!apiKey) throw new AnchorSandboxError("anchor_api_key_missing")
+  const host = resolveAnchorHost(options.platform)
+  const supervisor = resolveSupervisor(spec.supervisor, host)
+  const rootful = host === "windows-wsl" && supervisor === "wsl-root-systemd"
+  const environment = scrubHostEnvironment()
+  const limits = resolveLimits(spec)
+  const secret = secretName(spec.runID)
+  const cleanup = { spec, host, supervisor, limits, secret, runner, environment }
+  let operationFailed = false
+  let operationError: unknown
+  try {
+    // A deterministic name allows recovery after a crash before starting a new task with this run id.
+    await cleanupRuntimeResources(cleanup)
+    const paths = await resolveContainerPaths({ spec, host, runner, environment })
+    const variable = secretEnvironmentName(spec.runID)
+    const image = resolveImage(spec)
+    const created = await runner.run(
+      buildPodmanCommand({
+        host,
+        distro: spec.wslDistro,
+        supervisor,
+        operation: "manage",
+        podmanArgs: buildSecretCreateArgs(secret, variable),
+        limits,
+      }),
+      {
+        env: buildSecretEnvironment({ host, environment, variable, value: apiKey }),
+        envMode: "replace",
+        nothrow: true,
+      },
+    )
+    if (created.code !== 0) throw new AnchorSandboxError("anchor_secret_create_failed")
+    return await withHostTimeout(limits.timeout, (abort) =>
+      runner.run(
+        buildPodmanCommand({
+          host,
+          distro: spec.wslDistro,
+          supervisor,
+          operation: "run",
+          podmanArgs: buildContainerRunArgs({
+            image,
+            runID: spec.runID,
+            paths: paths.container,
+            limits,
+            rootful,
+            secret,
+            opencodeArgs,
+          }),
+          limits,
+          unit: systemdUnitName(spec.runID),
+        }),
+        { env: environment, envMode: "replace", abort, timeout: 5_000, nothrow: true },
+      ),
+    )
+  } catch (error) {
+    operationFailed = true
+    operationError = error
+    throw error
+  } finally {
+    try {
+      await cleanupRuntimeResources(cleanup)
+    } catch (cleanupError) {
+      if (operationFailed) {
+        throw new AggregateError([operationError, cleanupError], "anchor_run_and_cleanup_failed")
+      }
+      throw cleanupError
+    }
+  }
+}
+
+export async function exportSandboxed(
+  spec: AnchorSandboxSpec,
+  sessionID: string,
+  options: { runner?: CommandRunner; platform?: NodeJS.Platform } = {},
+) {
+  const runner = options.runner ?? systemRunner
+  const host = resolveAnchorHost(options.platform)
+  const supervisor = resolveSupervisor(spec.supervisor, host)
+  const rootful = host === "windows-wsl" && supervisor === "wsl-root-systemd"
+  const environment = scrubHostEnvironment()
+  const limits = resolveLimits(spec)
+  const paths = await resolveContainerPaths({ spec, host, runner, environment })
+  const image = resolveImage(spec)
+  try {
+    return await withHostTimeout(limits.timeout, (abort) =>
+      runner.run(
+        buildPodmanCommand({
+          host,
+          distro: spec.wslDistro,
+          supervisor,
+          operation: "run",
+          podmanArgs: buildContainerExportArgs({
+            image,
+            runID: spec.runID,
+            paths: paths.container,
+            limits,
+            rootful,
+            sessionID,
+          }),
+          limits,
+          unit: systemdUnitName(spec.runID),
+        }),
+        { env: environment, envMode: "replace", abort, timeout: 5_000, nothrow: true },
+      ),
+    )
+  } finally {
+    await removeContainer({ spec, host, supervisor, limits, runner, environment })
+  }
+}
+
+export async function cleanupSandboxed(
+  input: Pick<AnchorSandboxSpec, "workspace" | "runID" | "wslDistro" | "supervisor">,
+  options: { runner?: CommandRunner; platform?: NodeJS.Platform } = {},
+) {
+  const workspace = absolute(input.workspace, "anchor_workspace_not_absolute")
+  const state = path.join(workspace, ".anchor", "sandbox", validateRunID(input.runID))
+  const runner = options.runner ?? systemRunner
+  const host = resolveAnchorHost(options.platform)
+  const supervisor = resolveSupervisor(input.supervisor, host)
+  const environment = scrubHostEnvironment()
+  const limits = resolveLimits({})
+  const errors: unknown[] = []
+  try {
+    await cleanupRuntimeResources({
+      spec: input,
+      host,
+      supervisor,
+      limits,
+      secret: secretName(input.runID),
+      runner,
+      environment,
+    })
+  } catch (error) {
+    errors.push(error)
+  }
+  try {
+    await rm(state, { recursive: true, force: true })
+  } catch (error) {
+    errors.push(error)
+  }
+  if (errors.length === 1) throw errors[0]
+  if (errors.length > 1) throw new AggregateError(errors, "anchor_cleanup_failed")
+}
