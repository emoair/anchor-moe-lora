{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://anchor-moe-lora.local/schemas/synthetic-nl-scaffold-diagnostic-manifest-v1.json",
    "title": "Synthetic natural-language scaffold diagnostic manifest v1",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "schema_version",
        "status",
        "claim_scope",
        "producer",
        "counts",
        "generation_contract",
        "split_contract",
        "pair_contract",
        "partitions",
        "inventories",
        "read_set",
        "protected_inventory_status",
        "source_disjoint_boundary",
        "token_length_contract",
        "ablation_contract",
        "claims",
        "audit"
    ],
    "properties": {
        "schema_version": {
            "const": "anchor.synthetic-nl-scaffold-diagnostic-manifest.v1"
        },
        "status": {"const": "dataset_proxy_ready_training_not_authorized"},
        "claim_scope": {
            "const": "synthetic_diagnostic_only_no_formal_or_training_authority"
        },
        "producer": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "producer_version",
                "config",
                "config_schema",
                "closed_grammar",
                "closed_grammar_schema",
                "record_schema",
                "manifest_schema",
                "implementation",
                "canonical_json_policy",
                "atomic_publish",
                "final_toctou_recheck"
            ],
            "properties": {
                "producer_version": {
                    "const": "anchor.synthetic-nl-scaffold-diagnostic-producer.v1"
                },
                "config": {"$ref": "#/$defs/artifact"},
                "config_schema": {"$ref": "#/$defs/artifact"},
                "closed_grammar": {"$ref": "#/$defs/artifact"},
                "closed_grammar_schema": {"$ref": "#/$defs/artifact"},
                "record_schema": {"$ref": "#/$defs/artifact"},
                "manifest_schema": {"$ref": "#/$defs/artifact"},
                "implementation": {"$ref": "#/$defs/artifact"},
                "canonical_json_policy": {
                    "const": "utf8_sort_keys_compact_no_normalization_lf_v1"
                },
                "atomic_publish": {"const": true},
                "final_toctou_recheck": {"const": true}
            }
        },
        "counts": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "records",
                "pairs",
                "source_bundles",
                "roles",
                "languages",
                "variants",
                "train_records",
                "eval_proxy_records"
            ],
            "properties": {
                "records": {"const": 100},
                "pairs": {"const": 50},
                "source_bundles": {"const": 10},
                "roles": {"const": 5},
                "languages": {"const": 2},
                "variants": {"const": 2},
                "train_records": {"const": 80},
                "eval_proxy_records": {"const": 20}
            }
        },
        "generation_contract": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "seed_id",
                "seed_sha256",
                "source_namespace",
                "augmentation",
                "split_before_augmentation"
            ],
            "properties": {
                "seed_id": {"const": "anchor.synthetic-nl-scaffold-diagnostic.seed.v1"},
                "seed_sha256": {"$ref": "#/$defs/sha256"},
                "source_namespace": {
                    "const": "anchor.synthetic-nl-scaffold-diagnostic.v1"
                },
                "augmentation": {"const": "none"},
                "split_before_augmentation": {"const": true}
            }
        },
        "split_contract": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "group_key",
                "algorithm",
                "salt_sha256",
                "train_bundle_ids",
                "eval_proxy_bundle_ids",
                "all_role_variant_views_same_split",
                "eval_proxy_is_heldout"
            ],
            "properties": {
                "group_key": {"const": "source_bundle_id"},
                "algorithm": {
                    "const": "sha256_utf8_salt_nul_language_nul_bundle_key_sort_ascending_eval_one_per_language_v1"
                },
                "salt_sha256": {"$ref": "#/$defs/sha256"},
                "train_bundle_ids": {
                    "type": "array",
                    "minItems": 8,
                    "maxItems": 8,
                    "uniqueItems": true,
                    "items": {"$ref": "#/$defs/bundle_id"}
                },
                "eval_proxy_bundle_ids": {
                    "type": "array",
                    "minItems": 2,
                    "maxItems": 2,
                    "uniqueItems": true,
                    "items": {"$ref": "#/$defs/bundle_id"}
                },
                "all_role_variant_views_same_split": {"const": true},
                "eval_proxy_is_heldout": {"const": false}
            }
        },
        "pair_contract": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "variants",
                "same_input_sha256",
                "same_canonical_json_sha256",
                "same_allowed_and_forbidden_segments",
                "rationale_is_hidden_chain_of_thought"
            ],
            "properties": {
                "variants": {"const": ["json_only", "concise_rationale_plus_json"]},
                "same_input_sha256": {"const": true},
                "same_canonical_json_sha256": {"const": true},
                "same_allowed_and_forbidden_segments": {"const": true},
                "rationale_is_hidden_chain_of_thought": {"const": false}
            }
        },
        "partitions": {
            "type": "array",
            "minItems": 4,
            "maxItems": 4,
            "prefixItems": [
                {
                    "allOf": [
                        {"$ref": "#/$defs/partition"},
                        {
                            "properties": {
                                "path": {"const": "train/json_only.jsonl"},
                                "split": {"const": "train"},
                                "variant": {"const": "json_only"},
                                "records": {"const": 40}
                            }
                        }
                    ]
                },
                {
                    "allOf": [
                        {"$ref": "#/$defs/partition"},
                        {
                            "properties": {
                                "path": {"const": "train/concise_rationale_plus_json.jsonl"},
                                "split": {"const": "train"},
                                "variant": {"const": "concise_rationale_plus_json"},
                                "records": {"const": 40}
                            }
                        }
                    ]
                },
                {
                    "allOf": [
                        {"$ref": "#/$defs/partition"},
                        {
                            "properties": {
                                "path": {"const": "eval_proxy/json_only.jsonl"},
                                "split": {"const": "eval_proxy"},
                                "variant": {"const": "json_only"},
                                "records": {"const": 10}
                            }
                        }
                    ]
                },
                {
                    "allOf": [
                        {"$ref": "#/$defs/partition"},
                        {
                            "properties": {
                                "path": {"const": "eval_proxy/concise_rationale_plus_json.jsonl"},
                                "split": {"const": "eval_proxy"},
                                "variant": {"const": "concise_rationale_plus_json"},
                                "records": {"const": 10}
                            }
                        }
                    ]
                }
            ],
            "items": false
        },
        "inventories": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "record_ids_sha256",
                "record_content_sha256",
                "pair_ids_sha256",
                "source_bundle_ids_sha256",
                "arm_record_inventory_sha256"
            ],
            "properties": {
                "record_ids_sha256": {"$ref": "#/$defs/sha256"},
                "record_content_sha256": {"$ref": "#/$defs/sha256"},
                "pair_ids_sha256": {"$ref": "#/$defs/sha256"},
                "source_bundle_ids_sha256": {"$ref": "#/$defs/sha256"},
                "arm_record_inventory_sha256": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["q_only", "q_plus_o", "wide_lora"],
                    "properties": {
                        "q_only": {"$ref": "#/$defs/sha256"},
                        "q_plus_o": {"$ref": "#/$defs/sha256"},
                        "wide_lora": {"$ref": "#/$defs/sha256"}
                    }
                }
            }
        },
        "read_set": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "scope",
                "ordered_artifacts",
                "ordered_artifacts_sha256",
                "protected_source_paths_read"
            ],
            "properties": {
                "scope": {"const": "declared_semantic_generation_inputs_only"},
                "ordered_artifacts": {
                    "type": "array",
                    "minItems": 7,
                    "maxItems": 7,
                    "prefixItems": [
                        {"allOf": [{"$ref": "#/$defs/artifact"}, {"properties": {"path": {"const": "configs/research/synthetic_nl_scaffold_diagnostic_v1.yaml"}}}]},
                        {"allOf": [{"$ref": "#/$defs/artifact"}, {"properties": {"path": {"const": "configs/research/synthetic_nl_scaffold_diagnostic_v1_config.schema.json"}}}]},
                        {"allOf": [{"$ref": "#/$defs/artifact"}, {"properties": {"path": {"const": "configs/research/synthetic_nl_scaffold_diagnostic_v1_closed_grammar.json"}}}]},
                        {"allOf": [{"$ref": "#/$defs/artifact"}, {"properties": {"path": {"const": "configs/research/synthetic_nl_scaffold_diagnostic_v1_closed_grammar.schema.json"}}}]},
                        {"allOf": [{"$ref": "#/$defs/artifact"}, {"properties": {"path": {"const": "configs/research/synthetic_nl_scaffold_diagnostic_v1.schema.json"}}}]},
                        {"allOf": [{"$ref": "#/$defs/artifact"}, {"properties": {"path": {"const": "configs/research/synthetic_nl_scaffold_diagnostic_v1_manifest.schema.json"}}}]},
                        {"allOf": [{"$ref": "#/$defs/artifact"}, {"properties": {"path": {"const": "src/anchor_mvp/research/synthetic_nl_scaffold_diagnostic_v1.py"}}}]}
                    ],
                    "items": false
                },
                "ordered_artifacts_sha256": {"$ref": "#/$defs/sha256"},
                "protected_source_paths_read": {"const": 0}
            }
        },
        "protected_inventory_status": {
            "type": "object",
            "additionalProperties": false,
            "required": ["consumes_protected_inventories", "statuses"],
            "properties": {
                "consumes_protected_inventories": {"const": false},
                "statuses": {
                    "const": {
                        "swebench_source": "unavailable_not_read",
                        "gold_partition": "unavailable_not_read",
                        "partial_gold_export": "unavailable_not_read",
                        "heldout": "unavailable_not_read",
                        "legacy_heldout_cases": "unavailable_not_read",
                        "synthetic_scaffold": "unavailable_not_read"
                    }
                }
            }
        },
        "source_disjoint_boundary": {
            "const": {
                "source_namespace": "anchor.synthetic-nl-scaffold-diagnostic.v1",
                "zero_intersection_claimed": false,
                "source_disjoint_attestation_emitted": false,
                "formal_source_disjoint_proven": false,
                "status": "unavailable_without_protected_inventory_identities"
            }
        },
        "token_length_contract": {
            "const": {
                "status": "tokenizer_unbound",
                "token_counts_emitted": false,
                "truncation_allowed": false,
                "run_preflight_must_bind_tokenizer_and_full_chat_plus_target_lengths": true,
                "diagnostic_target_max_tokens": 1024,
                "diagnostic_preferred_p95_tokens": 768
            }
        },
        "ablation_contract": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "labels",
                "same_record_inventory_for_all_arms",
                "assignment_location",
                "producer_selects_winner",
                "target_modules_bound_by_dataset"
            ],
            "properties": {
                "labels": {"const": ["q_only", "q_plus_o", "wide_lora"]},
                "same_record_inventory_for_all_arms": {"const": true},
                "assignment_location": {"const": "diagnostic_run_manifest_only"},
                "producer_selects_winner": {"const": false},
                "target_modules_bound_by_dataset": {"const": false}
            }
        },
        "claims": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "dataset_proxy_ready",
                "diagnostic_only",
                "formal",
                "training_authorized",
                "quality_validated",
                "eval_proxy_is_heldout",
                "physical_kv_reuse_claimed",
                "numeric_equivalence_claimed"
            ],
            "properties": {
                "dataset_proxy_ready": {"const": true},
                "diagnostic_only": {"const": true},
                "formal": {"const": false},
                "training_authorized": {"const": false},
                "quality_validated": {"const": false},
                "eval_proxy_is_heldout": {"const": false},
                "physical_kv_reuse_claimed": {"const": false},
                "numeric_equivalence_claimed": {"const": false}
            }
        },
        "audit": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "record_schema_validated",
                "manifest_schema_validated",
                "bundle_split_disjoint",
                "pair_invariants_validated",
                "forbidden_content_excluded",
                "mandatory_sidecar",
                "protected_body_reads",
                "provider_requests",
                "network_requests",
                "model_loads",
                "gpu_requests",
                "real_tool_executions"
            ],
            "properties": {
                "record_schema_validated": {"const": true},
                "manifest_schema_validated": {"const": true},
                "bundle_split_disjoint": {"const": true},
                "pair_invariants_validated": {"const": true},
                "forbidden_content_excluded": {"const": true},
                "mandatory_sidecar": {"const": true},
                "protected_body_reads": {"const": 0},
                "provider_requests": {"const": 0},
                "network_requests": {"const": 0},
                "model_loads": {"const": 0},
                "gpu_requests": {"const": 0},
                "real_tool_executions": {"const": 0}
            }
        }
    },
    "$defs": {
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "bundle_id": {"type": "string", "pattern": "^syn-nl-bundle-v1:[0-9a-f]{64}$"},
        "artifact": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "bytes", "sha256"],
            "properties": {
                "path": {"type": "string", "minLength": 4, "maxLength": 256},
                "bytes": {"type": "integer", "minimum": 1, "maximum": 50000000},
                "sha256": {"$ref": "#/$defs/sha256"}
            }
        },
        "partition": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "split", "variant", "records", "bytes", "sha256"],
            "properties": {
                "path": {
                    "type": "string",
                    "pattern": "^(train|eval_proxy)/(json_only|concise_rationale_plus_json)\\.jsonl$"
                },
                "split": {"enum": ["train", "eval_proxy"]},
                "variant": {"enum": ["json_only", "concise_rationale_plus_json"]},
                "records": {"type": "integer", "minimum": 10, "maximum": 40},
                "bytes": {"type": "integer", "minimum": 1, "maximum": 50000000},
                "sha256": {"$ref": "#/$defs/sha256"}
            }
        }
    }
}
