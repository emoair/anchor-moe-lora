{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://anchor-moe-lora.local/schemas/synthetic-scaffold-independent-confirmation-identity-manifest-v1.json",
    "title": "Synthetic scaffold independent-confirmation identity fixture manifest v1",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "schema_version",
        "status",
        "claim_scope",
        "producer",
        "source",
        "counts",
        "identity_contract",
        "tracks",
        "partitions",
        "logical_inventories",
        "proofs",
        "read_set",
        "audit",
        "claims"
    ],
    "properties": {
        "schema_version": {
            "const": "anchor.synthetic-scaffold-independent-confirmation-identity-manifest.v1"
        },
        "status": {
            "const": "metadata_identity_assets_ready_execution_and_training_blocked"
        },
        "claim_scope": {
            "const": "metadata_only_diagnostic_identity_producer_non_authorizing"
        },
        "producer": {"$ref": "#/$defs/producer"},
        "source": {"$ref": "#/$defs/source"},
        "counts": {"$ref": "#/$defs/counts"},
        "identity_contract": {"$ref": "#/$defs/identityContract"},
        "tracks": {"$ref": "#/$defs/tracks"},
        "partitions": {
            "type": "array",
            "minItems": 8,
            "maxItems": 8,
            "items": {"$ref": "#/$defs/partition"}
        },
        "logical_inventories": {"$ref": "#/$defs/logicalInventories"},
        "proofs": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "items": {"$ref": "#/$defs/proofRef"}
        },
        "read_set": {"$ref": "#/$defs/readSet"},
        "audit": {"$ref": "#/$defs/audit"},
        "claims": {"$ref": "#/$defs/claims"}
    },
    "$defs": {
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "sha1": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "relPath": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_.-]+(?:/[A-Za-z0-9_.-]+)+$"
        },
        "artifact": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "bytes", "sha256"],
            "properties": {
                "path": {"$ref": "#/$defs/relPath"},
                "bytes": {"type": "integer", "minimum": 1, "maximum": 50000000},
                "sha256": {"$ref": "#/$defs/sha256"}
            }
        },
        "producer": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "producer_version",
                "config",
                "config_schema",
                "record_schema",
                "proof_schema",
                "manifest_schema",
                "implementation",
                "canonical_json_policy",
                "atomic_publish_no_replace",
                "final_toctou_recheck"
            ],
            "properties": {
                "producer_version": {
                    "const": "anchor.synthetic-scaffold-independent-confirmation-identity-producer.v1"
                },
                "config": {"$ref": "#/$defs/artifact"},
                "config_schema": {"$ref": "#/$defs/artifact"},
                "record_schema": {"$ref": "#/$defs/artifact"},
                "proof_schema": {"$ref": "#/$defs/artifact"},
                "manifest_schema": {"$ref": "#/$defs/artifact"},
                "implementation": {"$ref": "#/$defs/artifact"},
                "canonical_json_policy": {
                    "const": "utf8_sort_keys_compact_reject_nan_no_normalization_lf_for_documents_v1"
                },
                "atomic_publish_no_replace": {"const": true},
                "final_toctou_recheck": {"const": true}
            }
        },
        "source": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "repository",
                "source_commit",
                "source_parent_commit",
                "source_tree",
                "consumer_plan_commit",
                "consumer_plan_parent_commit",
                "consumer_plan_tree",
                "git_objects_authenticated",
                "config",
                "manifest",
                "manifest_sidecar",
                "consumer_plan_config",
                "generator_implementation_sha256",
                "closed_grammar_sha256",
                "source_bundle_inventory_sha256",
                "source_bundle_view_count",
                "source_record_count"
            ],
            "properties": {
                "repository": {"const": "anchor-moe-lora-neural-swarm"},
                "source_commit": {"$ref": "#/$defs/sha1"},
                "source_parent_commit": {"$ref": "#/$defs/sha1"},
                "source_tree": {"$ref": "#/$defs/sha1"},
                "consumer_plan_commit": {"$ref": "#/$defs/sha1"},
                "consumer_plan_parent_commit": {"$ref": "#/$defs/sha1"},
                "consumer_plan_tree": {"$ref": "#/$defs/sha1"},
                "git_objects_authenticated": {"const": true},
                "config": {"$ref": "#/$defs/artifact"},
                "manifest": {"$ref": "#/$defs/artifact"},
                "manifest_sidecar": {"$ref": "#/$defs/artifact"},
                "consumer_plan_config": {"$ref": "#/$defs/artifact"},
                "generator_implementation_sha256": {"$ref": "#/$defs/sha256"},
                "closed_grammar_sha256": {"$ref": "#/$defs/sha256"},
                "source_bundle_inventory_sha256": {"$ref": "#/$defs/sha256"},
                "source_bundle_view_count": {"const": 10},
                "source_record_count": {"const": 100}
            }
        },
        "counts": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "discovery_views",
                "discovery_unique_semantics",
                "independent_confirmation_bundles",
                "secondary_factorial_bundles",
                "metadata_bundle_rows",
                "records_if_both_tracks_materialized",
                "languages",
                "strata",
                "roles",
                "variants",
                "protected_body_reads",
                "provider_requests",
                "network_requests",
                "model_loads",
                "gpu_requests"
            ],
            "properties": {
                "discovery_views": {"const": 10},
                "discovery_unique_semantics": {"const": 5},
                "independent_confirmation_bundles": {"const": 60},
                "secondary_factorial_bundles": {"const": 60},
                "metadata_bundle_rows": {"const": 130},
                "records_if_both_tracks_materialized": {"const": 1200},
                "languages": {"const": 2},
                "strata": {"const": 5},
                "roles": {"const": 5},
                "variants": {"const": 2},
                "protected_body_reads": {"const": 0},
                "provider_requests": {"const": 0},
                "network_requests": {"const": 0},
                "model_loads": {"const": 0},
                "gpu_requests": {"const": 0}
            }
        },
        "identityContract": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "task_domain",
                "template_domain",
                "pair_domain",
                "task_bundle_domain",
                "source_task_blueprint_is_task_semantic_alias",
                "ontology_sha256",
                "descriptor_schema_sha256",
                "descriptor_atom_catalog_schema_version",
                "descriptor_atom_catalog_count",
                "descriptor_atom_catalog_sha256",
                "pair_recomputed_not_self_reported",
                "namespace_neutral_proof_identity_kinds"
            ],
            "properties": {
                "task_domain": {
                    "const": "anchor.controlled-factorial-task-identity.v1"
                },
                "template_domain": {
                    "const": "anchor.controlled-factorial-template-identity.v1"
                },
                "pair_domain": {
                    "const": "anchor.controlled-factorial-task-template-pair.v1"
                },
                "task_bundle_domain": {
                    "const": "anchor.synthetic-scaffold-controlled-proxy-confirmation-task-bundle.v1"
                },
                "source_task_blueprint_is_task_semantic_alias": {"const": true},
                "ontology_sha256": {"$ref": "#/$defs/sha256"},
                "descriptor_schema_sha256": {"$ref": "#/$defs/sha256"},
                "descriptor_atom_catalog_schema_version": {
                    "const": "anchor.synthetic-scaffold-common-domain-atom-catalog.v1"
                },
                "descriptor_atom_catalog_count": {"const": 241},
                "descriptor_atom_catalog_sha256": {
                    "const": "517f6b829bb78700b171a349d14541f75a9b76aa2a9267acb92a0e1a646d9545"
                },
                "pair_recomputed_not_self_reported": {"const": true},
                "namespace_neutral_proof_identity_kinds": {
                    "const": ["task_semantic", "template_family", "task_template_pair"]
                }
            }
        },
        "trackSummary": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "status",
                "bundles",
                "train",
                "eval_proxy",
                "expected_records_if_materialized",
                "materialized",
                "eval_proxy_is_heldout"
            ],
            "properties": {
                "status": {"type": "string", "minLength": 8, "maxLength": 128},
                "bundles": {"type": "integer", "minimum": 10, "maximum": 60},
                "train": {"type": "integer", "minimum": 8, "maximum": 40},
                "eval_proxy": {"type": "integer", "minimum": 2, "maximum": 20},
                "expected_records_if_materialized": {
                    "type": "integer",
                    "minimum": 100,
                    "maximum": 600
                },
                "materialized": {"const": false},
                "eval_proxy_is_heldout": {"const": false}
            }
        },
        "tracks": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "discovery_bridge",
                "producer_independent_confirmation",
                "secondary_controlled_factorial_probe"
            ],
            "properties": {
                "discovery_bridge": {"$ref": "#/$defs/trackSummary"},
                "producer_independent_confirmation": {"$ref": "#/$defs/trackSummary"},
                "secondary_controlled_factorial_probe": {
                    "$ref": "#/$defs/trackSummary"
                }
            }
        },
        "partition": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "media_type", "records", "bytes", "sha256"],
            "properties": {
                "path": {"$ref": "#/$defs/relPath"},
                "media_type": {"enum": ["application/x-ndjson", "application/json"]},
                "records": {"type": "integer", "minimum": 1, "maximum": 1000},
                "bytes": {"type": "integer", "minimum": 1, "maximum": 50000000},
                "sha256": {"$ref": "#/$defs/sha256"}
            }
        },
        "inventoryTriple": {
            "type": "object",
            "additionalProperties": false,
            "required": ["task", "template", "pair"],
            "properties": {
                "task": {"$ref": "#/$defs/inventoryDigest"},
                "template": {"$ref": "#/$defs/inventoryDigest"},
                "pair": {"$ref": "#/$defs/inventoryDigest"}
            }
        },
        "inventoryDigest": {
            "type": "object",
            "additionalProperties": false,
            "required": ["count", "sha256"],
            "properties": {
                "count": {"type": "integer", "minimum": 1, "maximum": 1000},
                "sha256": {"$ref": "#/$defs/sha256"}
            }
        },
        "logicalInventories": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "discovery_bridge",
                "producer_independent_confirmation",
                "secondary_controlled_factorial_probe",
                "union"
            ],
            "properties": {
                "discovery_bridge": {"$ref": "#/$defs/inventoryTriple"},
                "producer_independent_confirmation": {
                    "$ref": "#/$defs/inventoryTriple"
                },
                "secondary_controlled_factorial_probe": {
                    "$ref": "#/$defs/inventoryTriple"
                },
                "union": {"$ref": "#/$defs/inventoryTriple"}
            }
        },
        "proofRef": {
            "type": "object",
            "additionalProperties": false,
            "required": ["proof_kind", "path", "bytes", "sha256", "passed"],
            "properties": {
                "proof_kind": {
                    "enum": [
                        "discovery_vs_independent_confirmation",
                        "secondary_controlled_factorial_membership"
                    ]
                },
                "path": {"$ref": "#/$defs/relPath"},
                "bytes": {"type": "integer", "minimum": 1, "maximum": 50000000},
                "sha256": {"$ref": "#/$defs/sha256"},
                "passed": {"const": true}
            }
        },
        "readSet": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "scope",
                "producer_contract_artifacts",
                "source_metadata_artifacts",
                "consumer_contract_artifacts",
                "ordered_artifacts_sha256",
                "git_metadata_reads",
                "git_metadata_reads_sha256",
                "local_git_object_provenance_only",
                "source_git_commit_authenticated",
                "consumer_plan_git_commit_authenticated",
                "jsonl_inputs_read",
                "protected_body_reads"
            ],
            "properties": {
                "scope": {
                    "const": "exact_semantic_file_read_set_plus_local_git_object_provenance"
                },
                "producer_contract_artifacts": {
                    "type": "array",
                    "minItems": 6,
                    "maxItems": 6,
                    "items": {"$ref": "#/$defs/artifact"}
                },
                "source_metadata_artifacts": {
                    "type": "array",
                    "minItems": 3,
                    "maxItems": 3,
                    "items": {"$ref": "#/$defs/artifact"}
                },
                "consumer_contract_artifacts": {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 1,
                    "items": {"$ref": "#/$defs/artifact"}
                },
                "ordered_artifacts_sha256": {"$ref": "#/$defs/sha256"},
                "git_metadata_reads": {
                    "type": "array",
                    "minItems": 11,
                    "maxItems": 11,
                    "uniqueItems": true,
                    "items": {
                        "type": "string",
                        "minLength": 12,
                        "maxLength": 256
                    }
                },
                "git_metadata_reads_sha256": {"$ref": "#/$defs/sha256"},
                "local_git_object_provenance_only": {"const": true},
                "source_git_commit_authenticated": {"const": true},
                "consumer_plan_git_commit_authenticated": {"const": true},
                "jsonl_inputs_read": {"const": 0},
                "protected_body_reads": {"const": 0}
            }
        },
        "audit": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "config_schema_validated",
                "record_schema_validated",
                "proof_schema_validated",
                "manifest_schema_validated",
                "single_bytes_snapshot",
                "same_bytes_reparse",
                "final_toctou_recheck",
                "atomic_publish_no_replace",
                "exact_layout",
                "pair_leaves_recomputed",
                "discovery_bilingual_bridge_validated",
                "historical_discovery_semantic_split_intersection",
                "independent_task_zero_overlap",
                "independent_pair_zero_overlap",
                "factorial_truth_table_validated",
                "factorial_pair_zero_overlap",
                "provider_requests",
                "network_requests",
                "model_loads",
                "gpu_requests",
                "protected_body_reads"
            ],
            "properties": {
                "config_schema_validated": {"const": true},
                "record_schema_validated": {"const": true},
                "proof_schema_validated": {"const": true},
                "manifest_schema_validated": {"const": true},
                "single_bytes_snapshot": {"const": true},
                "same_bytes_reparse": {"const": true},
                "final_toctou_recheck": {"const": true},
                "atomic_publish_no_replace": {"const": true},
                "exact_layout": {"const": true},
                "pair_leaves_recomputed": {"const": true},
                "discovery_bilingual_bridge_validated": {"const": true},
                "historical_discovery_semantic_split_intersection": {"const": 2},
                "independent_task_zero_overlap": {"const": true},
                "independent_pair_zero_overlap": {"const": true},
                "factorial_truth_table_validated": {"const": true},
                "factorial_pair_zero_overlap": {"const": true},
                "provider_requests": {"const": 0},
                "network_requests": {"const": 0},
                "model_loads": {"const": 0},
                "gpu_requests": {"const": 0},
                "protected_body_reads": {"const": 0}
            }
        },
        "claims": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "metadata_identity_promotes_execution",
                "descriptor_zero_overlap_proves_real_world_semantic_disjointness",
                "automatic_translation_equivalence_proven",
                "records_materialized",
                "independent_confirmation_executed",
                "controlled_factorial_executed",
                "multi_seed_validated",
                "bundle_generalization_validated",
                "quality_validated",
                "eval_proxy_is_heldout",
                "training_authorized",
                "formal_training_authorized",
                "formal"
            ],
            "properties": {
                "metadata_identity_promotes_execution": {"const": false},
                "descriptor_zero_overlap_proves_real_world_semantic_disjointness": {
                    "const": false
                },
                "automatic_translation_equivalence_proven": {"const": false},
                "records_materialized": {"const": false},
                "independent_confirmation_executed": {"const": false},
                "controlled_factorial_executed": {"const": false},
                "multi_seed_validated": {"const": false},
                "bundle_generalization_validated": {"const": false},
                "quality_validated": {"const": false},
                "eval_proxy_is_heldout": {"const": false},
                "training_authorized": {"const": false},
                "formal_training_authorized": {"const": false},
                "formal": {"const": false}
            }
        }
    }
}
