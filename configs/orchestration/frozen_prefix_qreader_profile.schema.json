  "$defs": {
    "sha256_or_placeholder": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        {
          "const": "PLACEHOLDER_PENDING_PHYSICAL_FREEZE"
        }
      ]
    },
    "project_path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*\\\\)(?!.*(?:^|/)\\.\\.?(?:/|$))(?!.*//)[A-Za-z0-9_.-]+(?:/[A-Za-z0-9_.-]+)*$"
    },
    "file_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256",
        "bytes"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/project_path"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "bytes": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "dependency_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "path",
        "state",
        "sha256",
        "bytes"
      ],
      "properties": {
        "role": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]{1,79}$"
        },
        "path": {
          "$ref": "#/$defs/project_path"
        },
        "state": {
          "enum": [
            "bound",
            "pending_physical_freeze"
          ]
        },
        "sha256": {
          "$ref": "#/$defs/sha256_or_placeholder"
        },
        "bytes": {
          "type": "integer",
          "minimum": 0
        }
      },
      "allOf": [
        {
          "$ref": "#/$defs/dependency_role_path"
        },
        {
          "if": {
            "properties": {
              "state": {
                "const": "bound"
              }
            }
          },
          "then": {
            "properties": {
              "sha256": {
                "type": "string",
                "pattern": "^[0-9a-f]{64}$"
              },
              "bytes": {
                "minimum": 1
              }
            }
          },
          "else": {
            "properties": {
              "sha256": {
                "const": "PLACEHOLDER_PENDING_PHYSICAL_FREEZE"
              },
              "bytes": {
                "const": 0
              }
            }
          }
        }
      ]
    },
    "dependency_role_path": {
      "oneOf": [
        {"properties": {"role": {"const": "anchor_launcher"}, "path": {"const": "anchor.ps1"}}, "required": ["role", "path"]},
        {"properties": {"role": {"const": "full_bank_builder"}, "path": {"const": "scripts/data/build_swebench_full_bank.py"}}, "required": ["role", "path"]},
        {"properties": {"role": {"const": "full_bank_implementation"}, "path": {"const": "src/anchor_mvp/swebench/full_bank.py"}}, "required": ["role", "path"]},
