{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anchor-moe-lora.local/schemas/synthetic-nl-scaffold-diagnostic-record-v1.json",
  "title": "Synthetic natural-language scaffold diagnostic record v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_id",
    "pair_id",
    "source_bundle_id",
    "source_bundle_sha256",
    "split",
    "language",
    "role",
    "stage_index",
    "variant",
    "synthetic_source",
    "input",
    "board_segment_inventory",
    "forbidden_segment_ids",
    "target",
    "route_boundary",
    "ablation",
    "claims",
    "audit"
  ],
  "properties": {
    "schema_version": {
      "const": "anchor.synthetic-nl-scaffold-diagnostic-record.v1"
    },
    "record_id": {
      "type": "string",
      "pattern": "^syn-nl-record-v1:[0-9a-f]{64}$"
    },
    "pair_id": {
      "type": "string",
      "pattern": "^syn-nl-pair-v1:[0-9a-f]{64}$"
    },
    "source_bundle_id": {
      "type": "string",
      "pattern": "^syn-nl-bundle-v1:[0-9a-f]{64}$"
    },
    "source_bundle_sha256": { "$ref": "#/$defs/sha256" },
    "split": { "enum": ["train", "eval_proxy"] },
    "language": { "enum": ["en", "zh-CN"] },
    "role": { "$ref": "#/$defs/role" },
    "stage_index": { "type": "integer", "minimum": 0, "maximum": 4 },
    "variant": {
      "enum": ["json_only", "concise_rationale_plus_json"]
    },
    "synthetic_source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "bundle_key",
        "archetype",
        "closed_grammar_id",
        "closed_grammar_sha256",
        "generation_seed_id",
        "generation_seed_sha256",
        "generator_config_sha256",
        "generator_implementation_sha256"
      ],
      "properties": {
        "kind": { "const": "closed_grammar_synthetic_no_external_body" },
        "bundle_key": { "type": "string", "pattern": "^[a-z0-9_]+$" },
        "archetype": { "type": "string", "pattern": "^[a-z0-9_]+$" },
        "closed_grammar_id": {
          "const": "anchor.synthetic-nl-scaffold-closed-grammar.v1"
        },
        "closed_grammar_sha256": { "$ref": "#/$defs/sha256" },
        "generation_seed_id": {
          "const": "anchor.synthetic-nl-scaffold-diagnostic.seed.v1"
        },
        "generation_seed_sha256": { "$ref": "#/$defs/sha256" },
        "generator_config_sha256": { "$ref": "#/$defs/sha256" },
        "generator_implementation_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_text",
        "constraints",
        "role_instruction",
        "allowed_context_segments",
        "materialized_prompt",
        "input_sha256"
      ],
      "properties": {
        "task_text": { "type": "string", "minLength": 16, "maxLength": 1024 },
        "constraints": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": { "type": "string", "minLength": 4, "maxLength": 256 }
        },
        "role_instruction": {
          "type": "string",
          "minLength": 12,
          "maxLength": 512
        },
        "allowed_context_segments": {
          "type": "array",
          "maxItems": 4,
          "items": { "$ref": "#/$defs/visible_segment" }
        },
        "materialized_prompt": {
          "type": "string",
          "minLength": 32,
          "maxLength": 16384
        },
        "input_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "board_segment_inventory": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": { "$ref": "#/$defs/segment_inventory_entry" }
    },
    "forbidden_segment_ids": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/segment_id" }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonical_routing_json",
        "canonical_json_sha256",
        "concise_rationale_summary",
        "serialized_assistant_output",
        "output_sha256"
      ],
      "properties": {
        "canonical_routing_json": { "$ref": "#/$defs/route" },
        "canonical_json_sha256": { "$ref": "#/$defs/sha256" },
        "concise_rationale_summary": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "minLength": 8, "maxLength": 512 }
          ]
        },
        "serialized_assistant_output": {
          "type": "string",
          "minLength": 32,
          "maxLength": 16384
        },
        "output_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "route_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "semantics",
        "activation_semantics",
        "committed_scaffold_reencode_required",
        "planner_request1_private_kv_reused"
      ],
      "properties": {
        "semantics": { "const": "explicit_two_request_commit" },
        "activation_semantics": { "const": "next_request_input_activation_only" },
        "committed_scaffold_reencode_required": { "const": true },
        "planner_request1_private_kv_reused": { "const": false }
      }
    },
    "ablation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "eligible_labels",
        "assignment_location",
        "identical_inventory_required",
        "producer_selects_winner"
      ],
      "properties": {
        "eligible_labels": {
          "const": ["q_only", "q_plus_o", "wide_lora"]
        },
        "assignment_location": { "const": "diagnostic_run_manifest_only" },
        "identical_inventory_required": { "const": true },
        "producer_selects_winner": { "const": false }
      }
    },
    "claims": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "diagnostic_only",
        "formal",
        "training_authorized",
        "quality_validated",
        "proxy_signal_only",
        "physical_kv_reuse_claimed",
        "numeric_equivalence_claimed"
      ],
      "properties": {
        "diagnostic_only": { "const": true },
        "formal": { "const": false },
        "training_authorized": { "const": false },
        "quality_validated": { "const": false },
        "proxy_signal_only": { "const": true },
        "physical_kv_reuse_claimed": { "const": false },
        "numeric_equivalence_claimed": { "const": false }
      }
    },
    "audit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protected_body_reads",
        "provider_requests",
        "network_requests",
        "model_loads",
        "gpu_requests",
        "real_tool_executions"
      ],
      "properties": {
        "protected_body_reads": { "const": 0 },
        "provider_requests": { "const": 0 },
        "network_requests": { "const": 0 },
        "model_loads": { "const": 0 },
        "gpu_requests": { "const": 0 },
        "real_tool_executions": { "const": 0 }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "variant": { "const": "json_only" } },
        "required": ["variant"]
      },
      "then": {
        "properties": {
          "target": {
            "properties": {
              "concise_rationale_summary": { "type": "null" },
              "serialized_assistant_output": { "pattern": "^\\{[^\\r\\n]*\\}$" }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "variant": { "const": "concise_rationale_plus_json" }
        },
        "required": ["variant"]
      },
      "then": {
        "properties": {
          "target": {
            "properties": {
              "concise_rationale_summary": {
                "type": "string",
                "minLength": 8,
                "maxLength": 512,
                "pattern": "^[^\\r\\n]+$"
              },
              "serialized_assistant_output": {
                "pattern": "^[^\\r\\n]+\\n\\{[^\\r\\n]*\\}$"
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "role": {
      "enum": [
        "planner",
        "tool_policy",
        "frontend_gen",
        "frontend_review",
        "security_gate"
      ]
    },
    "segment_id": {
      "type": "string",
      "pattern": "^syn-nl-segment-v1:[0-9a-f]{64}$"
    },
    "segment_ref": {
      "type": "string",
      "pattern": "^S[0-4]$"
    },
    "visible_segment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["segment_id", "segment_ref", "role", "stage_index", "committed_summary", "committed_summary_sha256", "source_target_sha256"],
      "properties": {
        "segment_id": { "$ref": "#/$defs/segment_id" },
        "segment_ref": { "$ref": "#/$defs/segment_ref" },
        "role": { "$ref": "#/$defs/role" },
        "stage_index": { "type": "integer", "minimum": 0, "maximum": 3 },
        "committed_summary": { "type": "string", "minLength": 8, "maxLength": 512 },
        "committed_summary_sha256": { "$ref": "#/$defs/sha256" },
        "source_target_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "segment_inventory_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["segment_id", "segment_ref", "role", "stage_index", "content_sha256", "visibility"],
      "properties": {
        "segment_id": { "$ref": "#/$defs/segment_id" },
        "segment_ref": { "$ref": "#/$defs/segment_ref" },
        "role": { "$ref": "#/$defs/role" },
        "stage_index": { "type": "integer", "minimum": 0, "maximum": 4 },
        "content_sha256": { "$ref": "#/$defs/sha256" },
        "visibility": { "enum": ["previous_committed", "current_target", "future_target"] }
      }
    },
    "tool_plan_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "mode"],
      "properties": {
        "action": { "type": "string", "minLength": 3, "maxLength": 128 },
        "mode": { "const": "harmless_synthetic_fixture_trace" }
      }
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "expert",
        "goal",
        "constraints",
        "allowed_segment_refs",
        "evidence_segment_refs",
        "tool_plan",
        "acceptance_criteria"
      ],
      "properties": {
        "role": { "$ref": "#/$defs/role" },
        "expert": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "goal": { "type": "string", "minLength": 8, "maxLength": 512 },
        "constraints": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": { "type": "string", "minLength": 4, "maxLength": 256 }
        },
        "allowed_segment_refs": {
          "type": "array",
          "maxItems": 4,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/segment_ref" }
        },
        "evidence_segment_refs": {
          "type": "array",
          "maxItems": 4,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/segment_ref" }
        },
        "tool_plan": {
          "type": "array",
          "minItems": 1,
          "maxItems": 2,
          "items": { "$ref": "#/$defs/tool_plan_entry" }
        },
        "acceptance_criteria": {
          "type": "array",
          "minItems": 2,
          "maxItems": 4,
          "items": { "type": "string", "minLength": 4, "maxLength": 256 }
        }
      }
    }
  }
}
