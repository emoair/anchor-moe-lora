@@ -0,0 +1,225 @@
+import { expect, test } from "bun:test"
+import { mkdtemp, rm } from "node:fs/promises"
+import { tmpdir } from "node:os"
+import path from "node:path"
+import {
+  ANCHOR_ROUTE_CLIENT_TOKEN,
+  ANCHOR_ROUTE_PORT,
+  ANCHOR_ROUTE_SOCKET,
+  ANCHOR_TOOL_CONTRACT,
+  AnchorSandboxError,
+  buildContainerExportArgs,
+  buildContainerRunArgs,
+  cleanupSandboxed,
+  containerName,
+  exportSandboxed,
+  resolveAnchorHost,
+  resolveLimits,
+  resolveRouteDirectory,
+  resolveSandboxPaths,
+  resolveSupervisor,
+  routeUnitName,
+  runContainerRouteBridge,
+  runSandboxed,
+  scrubHostEnvironment,
+  validateLocalRouteTarget,
+  validateRunID,
+  type CommandRunner,
+} from "@/anchor/sandbox"
+import type { Result, RunOptions } from "@/util/process"
+
+function result(code = 0, stdout = "", stderr = ""): Result {
+  return { code, stdout: Buffer.from(stdout), stderr: Buffer.from(stderr) }
+}
+
+class FakeRunner implements CommandRunner {
+  readonly commands: string[][] = []
+  readonly options: (RunOptions | undefined)[] = []
+
+  async run(command: string[], options?: RunOptions): Promise<Result> {
+    this.commands.push(command)
+    this.options.push(options)
+    if (command.includes("wslpath")) return result(0, "/mnt/c/anchor-path\n")
+    if (command.includes("test") && command.includes("-S")) return result()
+    const podman = command.indexOf("podman")
+    const args = podman === -1 ? [] : command.slice(podman + 1)
+    if (args[0] === "run" && args.includes("export")) return result(0, '{"info":{"id":"ses_anchor"}}\n')
+    if (args[0] === "run") return result(0, '{"type":"step_start","sessionID":"ses_anchor"}\n')
+    return result()
+  }
+}
+
+const limits = { memory: "4G", cpus: 2, pids: 256, timeout: 900 }
+const paths = {
+  workspace: "/var/lib/anchor/tasks/task-01/testbed",
+  config: "/var/lib/anchor/tasks/task-01/opencode.json",
+  state: "/var/lib/anchor/tasks/task-01/state",
+  route: "/run/anchor-opencode/task-01",
+  linuxExecutable: "/var/lib/anchor/bin/opencode",
+}
+
+test("publishes the formal v3 tool contract and canonical testbed", () => {
+  expect(ANCHOR_TOOL_CONTRACT).toBe("anchor.execution-tool-contract.v3")
+  expect(validateRunID("task_01-ok")).toBe("task_01-ok")
+  expect(() => validateRunID("../escape")).toThrow("anchor_run_id_invalid")
+  const workspace = path.resolve("workspace")
+  const resolved = resolveSandboxPaths({ workspace, config: path.join(workspace, "opencode.json"), runID: "task-01" })
+  expect(resolved.workspace).toBe(workspace)
+})
+
+test("selects Windows WSL or native Linux supervisors", () => {
+  expect(resolveAnchorHost("win32")).toBe("windows-wsl")
+  expect(resolveAnchorHost("linux")).toBe("linux")
+  expect(resolveSupervisor(undefined, "windows-wsl")).toBe("wsl-root-systemd")
+  expect(resolveSupervisor(undefined, "linux")).toBe("direct")
+  expect(() => resolveSupervisor("wsl-root-systemd", "linux")).toThrow("anchor_supervisor_host_mismatch")
+  expect(resolveLimits({})).toEqual(limits)
+})
+
+test("accepts only a fixed private or loopback CC Switch target", () => {
+  expect(validateLocalRouteTarget("127.0.0.1", 18080)).toEqual({ host: "127.0.0.1", port: 18080 })
+  expect(validateLocalRouteTarget("172.20.0.1", 18081)).toEqual({ host: "172.20.0.1", port: 18081 })
+  expect(() => validateLocalRouteTarget("1.1.1.1", 443)).toThrow("anchor_route_host_not_local")
+  expect(() => validateLocalRouteTarget("169.254.169.254", 80)).toThrow("anchor_route_host_not_local")
+  expect(() => validateLocalRouteTarget("127.0.0.1", 0)).toThrow("anchor_route_port_invalid")
+})
+
+test("scrubs inherited credentials before supervisor or container launch", () => {
+  const environment = scrubHostEnvironment({
+    Path: "kept",
+    KIMI_CODE_API_KEY: "drop",
+    ARK_CODING_API_KEY: "drop",
+    providerToken: "drop",
+    DATABASE_PASSWORD: "drop",
+    WSLENV: "drop/u",
+  })
+  expect(environment).toEqual({ Path: "kept" })
+})
+
+test("uses a supervisor-private deterministic Unix socket directory", () => {
+  expect(resolveRouteDirectory("task-01", "windows-wsl")).toBe("/run/anchor-opencode/task-01")
+  expect(resolveRouteDirectory("task-01", "linux", { XDG_RUNTIME_DIR: "/run/user/1000" })).toBe(
+    "/run/user/1000/anchor-opencode/task-01",
+  )
+  expect(routeUnitName("task-01")).toBe("anchor-route-task-01")
+})
+
+test("constructs a network-none canonical /testbed model container with only the route socket", () => {
+  const args = buildContainerRunArgs({
+    image: "registry.example/instance@sha256:abc",
+    runID: "task-01",
+    paths,
+    limits,
+    rootful: true,
+    opencodeArgs: ["run", "--dir", "/testbed", "prompt"],
+  })
+  const rendered = args.join("\n")
+  expect(args).toContain("none")
+  expect(args).not.toContain("slirp4netns")
+  expect(rendered).toContain("dst=/testbed,rw")
+  expect(rendered).not.toContain("dst=/workspace")
+  expect(rendered).toContain("dst=/run/anchor-route,ro")
+  expect(rendered).toContain(`ANCHOR_LOCAL_ROUTE_CLIENT_TOKEN=${ANCHOR_ROUTE_CLIENT_TOKEN}`)
+  expect(rendered).not.toContain("--secret")
+  expect(rendered).not.toContain("KIMI_CODE_API_KEY")
+  expect(rendered).toContain("anchor _route-bridge")
+  expect(rendered).toContain("--cgroups=disabled")
+})
+
+test("constructs a fresh network-none export boundary without route socket or route token", () => {
+  const args = buildContainerExportArgs({
+    image: "registry.example/instance@sha256:abc",
+    runID: "task-01",
+    paths,
+    limits,
+    rootful: true,
+    sessionID: "ses_anchor",
+  })
+  const rendered = args.join("\n")
+  expect(args.filter((item) => item === "--network")).toHaveLength(1)
+  expect(args).toContain("none")
+  expect(rendered).not.toContain("/run/anchor-route")
+  expect(rendered).not.toContain("ANCHOR_LOCAL_ROUTE_CLIENT_TOKEN")
+  expect(rendered).not.toContain("_route-bridge")
+})
+
+test("the in-container bridge target is immutable", () => {
+  expect(ANCHOR_ROUTE_SOCKET).toBe("/run/anchor-route/ccswitch.sock")
+  expect(ANCHOR_ROUTE_PORT).toBe(18080)
+  expect(() => runContainerRouteBridge("/tmp/attacker.sock", 18080)).toThrow("anchor_route_bridge_target_invalid")
+  expect(() => runContainerRouteBridge(ANCHOR_ROUTE_SOCKET, 8080)).toThrow("anchor_route_bridge_target_invalid")
+})
+
+test("formal run starts a fixed-filter relay and destroys container, unit, and socket directory", async () => {
+  const workspace = await mkdtemp(path.join(tmpdir(), "anchor-v3-"))
+  const runner = new FakeRunner()
+  try {
+    const response = await runSandboxed(
+      {
+        workspace,
+        config: path.join(workspace, "opencode.json"),
+        runID: "task-formal",
+        wslDistro: "Ubuntu-22.04",
+        linuxExecutable: path.join(workspace, "opencode"),
+        image: "registry.example/instance@sha256:abc",
+        routeHost: "172.20.0.1",
+        routePort: 18080,
+      },
+      ["run", "--dir", "/testbed", "prompt"],
+      { runner, platform: "win32" },
+    )
+    expect(response.code).toBe(0)
+    const relay = runner.commands.find((command) => command.includes("systemd-run") && command.includes("python3"))
+    expect(relay).toBeDefined()
+    const relaySource = relay?.[relay.indexOf("-c") + 1] ?? ""
+    expect(relaySource).toContain("parts[0].upper()==b'CONNECT'")
+    expect(relaySource).toContain("hosts != [b'127.0.0.1:18080']")
+    expect(relaySource).toContain("target.split(b'?',1)[0] not in allowed")
+    expect(relay).toContain("172.20.0.1")
+    const model = runner.commands.find((command) => command.includes("podman") && command.includes("run"))
+    expect(model).toContain("none")
+    expect(model).not.toContain("slirp4netns")
+    expect(
+      runner.commands.some((command) => command.includes("rm") && command.includes(containerName("task-formal"))),
+    ).toBe(true)
+    expect(runner.commands.some((command) => command.includes("systemctl") && command.includes("stop"))).toBe(true)
+    expect(
+      runner.commands.some((command) => command.includes("rm") && command.includes("/run/anchor-opencode/task-formal")),
+    ).toBe(true)
+    expect(runner.options.every((option) => option?.envMode === "replace")).toBe(true)
+  } finally {
+    await cleanupSandboxed(
+      { workspace, runID: "task-formal", wslDistro: "Ubuntu-22.04" },
+      { runner, platform: "win32" },
+    )
+    await rm(workspace, { recursive: true, force: true })
+  }
+})
+
+test("fresh export performs stale model/socket cleanup before offline launch", async () => {
+  const workspace = await mkdtemp(path.join(tmpdir(), "anchor-v3-export-"))
+  const runner = new FakeRunner()
+  try {
+    const response = await exportSandboxed(
+      {
+        workspace,
+        config: path.join(workspace, "opencode.json"),
+        runID: "task-export",
+        wslDistro: "Ubuntu-22.04",
+        image: "registry.example/instance@sha256:abc",
+      },
+      "ses_anchor",
+      { runner, platform: "win32" },
+    )
+    expect(response.code).toBe(0)
+    const launch = runner.commands.findIndex((command) => command.includes("podman") && command.includes("run"))
+    const stop = runner.commands.findIndex((command) => command.includes("systemctl") && command.includes("stop"))
+    expect(stop).toBeGreaterThanOrEqual(0)
+    expect(stop).toBeLessThan(launch)
+    const args = runner.commands[launch].join("\n")
+    expect(args).toContain("--network\nnone")
+    expect(args).not.toContain("/run/anchor-route")
+  } finally {
+    await rm(workspace, { recursive: true, force: true })
+  }
+})
