  "title": "Qwen training prerequisite status",
  "description": "Content-free, fail-closed status for the Qwen2.5-1.5B-Instruct diagnostic training prerequisites. This status never authorizes formal training and never carries Gold, held-out, scaffold, prompt, answer, or token bodies.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "claim_scope",
    "producer",
    "policy_bindings",
    "formal_artifacts",
    "raw_gold_observation",
    "tokenizer_binding",
    "toy_attestation",
    "consumer_freeze_requirements",
    "safety"
  ],
  "properties": {
    "schema_version": {
      "const": "anchor.qwen-train-prerequisite-status.v1"
    },
    "status": {"const": "blocked"},
    "claim_scope": {
      "const": "content_free_prerequisite_status_only_no_training_authority"
    },
    "producer": {"$ref": "#/$defs/producer"},
    "policy_bindings": {"$ref": "#/$defs/policy_bindings"},
    "formal_artifacts": {"$ref": "#/$defs/formal_artifacts"},
    "raw_gold_observation": {"$ref": "#/$defs/raw_gold_observation"},
    "tokenizer_binding": {"$ref": "#/$defs/tokenizer_binding"},
    "toy_attestation": {"$ref": "#/$defs/toy_attestation"},
    "consumer_freeze_requirements": {
      "$ref": "#/$defs/consumer_freeze_requirements"
    },
    "safety": {"$ref": "#/$defs/safety"}
  },
