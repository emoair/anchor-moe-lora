+import { Effect } from "effect"
+import type { Argv } from "yargs"
+import {
+  AnchorSandboxError,
+  cleanupSandboxed,
+  exportSandboxed,
+  runSandboxed,
+  type AnchorSandboxSpec,
+  type AnchorSupervisor,
+} from "@/anchor/sandbox"
+import { effectCmd, fail } from "../effect-cmd"
+import { cmd } from "./cmd"
+
+interface SharedArgs {
+  workspace: string
+  config: string
+  "run-id": string
+  "wsl-distro"?: string
+  "linux-executable"?: string
+  memory: string
+  cpus: number
+  pids: number
+  timeout: number
+  supervisor: AnchorSupervisor
+}
+
+interface CleanupArgs {
+  workspace: string
+  "run-id": string
+  "wsl-distro"?: string
+  supervisor: AnchorSupervisor
+}
+
+const DEFAULT_SUPERVISOR: AnchorSupervisor = process.platform === "win32" ? "wsl-root-systemd" : "direct"
+
+function shared(yargs: Argv) {
+  return yargs
+    .option("workspace", {
+      type: "string",
+      demandOption: true,
+      describe: "absolute host workspace directory mounted as /workspace",
+    })
+    .option("config", {
+      type: "string",
+      demandOption: true,
+      describe: "absolute host OpenCode config file mounted read-only",
+    })
+    .option("run-id", {
+      type: "string",
+      demandOption: true,
+      describe: "safe per-task sandbox identifier",
+    })
+    .option("wsl-distro", {
+      type: "string",
+      describe: "WSL distribution hosting Podman (required only on Windows)",
+    })
+    .option("linux-executable", {
+      type: "string",
+      describe: "optional absolute host Linux OpenCode binary mounted read-only",
+    })
+    .option("memory", {
+      type: "string",
+      default: "4G",
+      describe: "task memory limit",
+    })
+    .option("cpus", {
+      type: "number",
+      default: 2,
+      describe: "task CPU limit",
+    })
+    .option("pids", {
+      type: "number",
+      default: 256,
+      describe: "task PID limit",
+    })
+    .option("timeout", {
+      type: "number",
+      default: 900,
+      describe: "host and systemd-run task timeout in seconds",
+    })
+    .option("supervisor", {
+      type: "string",
+      choices: ["direct", "wsl-root-systemd"] as const,
+      default: DEFAULT_SUPERVISOR,
+      describe: "execution supervisor (Windows defaults to root systemd-run; Linux defaults to direct)",
+    })
+}
+
+function spec(args: SharedArgs): AnchorSandboxSpec {
+  return {
+    workspace: args.workspace,
+    config: args.config,
+    runID: args["run-id"],
+    wslDistro: args["wsl-distro"],
+    linuxExecutable: args["linux-executable"],
+    memory: args.memory,
+    cpus: args.cpus,
+    pids: args.pids,
+    timeout: args.timeout,
+    supervisor: args.supervisor,
+  }
+}
+
+function cleanupSpec(args: CleanupArgs) {
+  return {
+    workspace: args.workspace,
+    runID: args["run-id"],
+    wslDistro: args["wsl-distro"],
+    supervisor: args.supervisor,
+  }
+}
+
+function writeResult(result: { stdout: Buffer; stderr: Buffer }) {
+  if (result.stdout.length) process.stdout.write(result.stdout)
+  if (result.stderr.length) process.stderr.write(result.stderr)
+}
+
+function domainError(error: unknown) {
+  return error instanceof AnchorSandboxError ? error.code : "anchor_sandbox_failed"
+}
+
+export const AnchorRunCommand = effectCmd({
+  command: "run [message..]",
+  describe: "run one Anchor distillation task inside a WSL Podman sandbox",
+  instance: false,
+  builder: (yargs: Argv) =>
+    shared(yargs)
+      .positional("message", { type: "string", array: true, default: [], describe: "message to send" })
+      .option("model", { type: "string", demandOption: true })
+      .option("agent", { type: "string", demandOption: true })
+      .option("variant", { type: "string", demandOption: true })
+      .option("title", { type: "string", demandOption: true })
+      .option("format", { type: "string", choices: ["default", "json"] as const, default: "json" as const }),
+  handler: Effect.fn("Cli.anchor.run")(function* (args) {
+    try {
+      const inner = [
+        "run",
+        "--dir",
+        "/workspace",
+        "--format",
+        args.format,
+        "--model",
+        args.model,
+        "--agent",
+        args.agent,
+        "--variant",
+        args.variant,
+        "--title",
+        args.title,
+        ...args.message,
+        ...(args["--"] ?? []),
+      ]
+      const result = yield* Effect.promise(() => runSandboxed(spec(args), inner))
+      writeResult(result)
+      if (result.code !== 0) return yield* fail("Anchor sandbox run failed", result.code)
+    } catch (error) {
+      return yield* fail(domainError(error))
+    }
+  }),
+})
+
+export const AnchorExportCommand = effectCmd({
+  command: "export",
+  describe: "export a session from an Anchor sandbox state directory",
+  instance: false,
+  builder: (yargs: Argv) =>
+    shared(yargs).option("session", { type: "string", demandOption: true, describe: "session id to export" }),
+  handler: Effect.fn("Cli.anchor.export")(function* (args) {
+    try {
+      const result = yield* Effect.promise(() => exportSandboxed(spec(args), args.session))
+      writeResult(result)
+      if (result.code !== 0) return yield* fail("Anchor sandbox export failed", result.code)
+    } catch (error) {
+      return yield* fail(domainError(error))
+    }
+  }),
+})
+
+export const AnchorCleanupCommand = effectCmd({
+  command: "cleanup",
+  describe: "remove stale per-task Podman resources and the Anchor sandbox state directory",
+  instance: false,
+  builder: (yargs: Argv) =>
+    yargs
+      .option("workspace", { type: "string", demandOption: true, describe: "absolute host workspace directory" })
+      .option("run-id", { type: "string", demandOption: true, describe: "safe per-task sandbox identifier" })
+      .option("wsl-distro", {
+        type: "string",
+        describe: "WSL distribution hosting Podman (required only on Windows)",
+      })
+      .option("supervisor", {
+        type: "string",
+        choices: ["direct", "wsl-root-systemd"] as const,
+        default: DEFAULT_SUPERVISOR,
+        describe: "execution supervisor used for the task to clean",
+      }),
+  handler: Effect.fn("Cli.anchor.cleanup")(function* (args) {
+    try {
+      yield* Effect.promise(() => cleanupSandboxed(cleanupSpec(args)))
+    } catch (error) {
+      return yield* fail(domainError(error))
+    }
+  }),
+})
+
+export const AnchorCommand = cmd({
+  command: "anchor",
+  describe: "run Anchor distillation tasks through WSL Podman sandboxes",
+  builder: (yargs) =>
+    yargs.command(AnchorRunCommand).command(AnchorExportCommand).command(AnchorCleanupCommand).demandCommand(),
+  async handler() {},
+})
