{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://anchor-moe-lora.local/schemas/synthetic-scaffold-independent-confirmation-identity-record-v1.json",
    "title": "Body-free identity records for independent confirmation v1",
    "oneOf": [
        {"$ref": "#/$defs/discoveryView"},
        {"$ref": "#/$defs/independentBundle"},
        {"$ref": "#/$defs/factorialBundle"},
        {"$ref": "#/$defs/identityInventory"}
    ],
    "$defs": {
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "atom": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
        "language": {"enum": ["en", "zh-CN"]},
        "split": {"enum": ["train", "eval_proxy"]},
        "roles": {
            "const": [
                "planner",
                "tool_policy",
                "frontend_gen",
                "frontend_review",
                "security_gate"
            ]
        },
        "variants": {"const": ["json_only", "concise_rationale_plus_json"]},
        "identityLeaves": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "task_semantic_sha256",
                "source_task_blueprint_sha256",
                "template_family_sha256",
                "task_template_pair_sha256"
            ],
            "properties": {
                "task_semantic_sha256": {"$ref": "#/$defs/sha256"},
                "source_task_blueprint_sha256": {"$ref": "#/$defs/sha256"},
                "template_family_sha256": {"$ref": "#/$defs/sha256"},
                "task_template_pair_sha256": {"$ref": "#/$defs/sha256"}
            }
        },
        "bundleExpansion": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "ordered_roles",
                "ordered_variants",
                "expected_record_count",
                "split_before_role_variant_expansion",
                "all_views_same_split"
            ],
            "properties": {
                "ordered_roles": {"$ref": "#/$defs/roles"},
                "ordered_variants": {"$ref": "#/$defs/variants"},
                "expected_record_count": {"const": 10},
                "split_before_role_variant_expansion": {"const": true},
                "all_views_same_split": {"const": true}
            }
        },
        "discoveryView": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "schema_version",
                "record_kind",
                "track",
                "source_bundle_key",
                "source_bundle_id",
                "source_bundle_payload_sha256",
                "localized_view_sha256",
                "source_goal_sha256",
                "ordered_source_constraint_sha256s",
                "source_clause_count",
                "semantic_atom_inventory_sha256",
                "semantic_coverage_map_sha256",
                "language",
                "split",
                "semantic_group_sha256",
                "identities",
                "expansion",
                "curated_bridge_not_automatic_translation_proof"
            ],
            "properties": {
                "schema_version": {
                    "const": "anchor.synthetic-scaffold-independent-confirmation-identity-record.v1"
                },
                "record_kind": {"const": "discovery_view"},
                "track": {"const": "discovery_bridge"},
                "source_bundle_key": {
                    "type": "string",
                    "pattern": "^(en|zh)_[a-z0-9_]+$"
                },
                "source_bundle_id": {
                    "type": "string",
                    "pattern": "^syn-nl-bundle-v1:[0-9a-f]{64}$"
                },
                "source_bundle_payload_sha256": {"$ref": "#/$defs/sha256"},
                "localized_view_sha256": {"$ref": "#/$defs/sha256"},
                "source_goal_sha256": {"$ref": "#/$defs/sha256"},
                "ordered_source_constraint_sha256s": {
                    "type": "array",
                    "minItems": 3,
                    "maxItems": 3,
                    "items": {"$ref": "#/$defs/sha256"}
                },
                "source_clause_count": {"const": 4},
                "semantic_atom_inventory_sha256": {"$ref": "#/$defs/sha256"},
                "semantic_coverage_map_sha256": {"$ref": "#/$defs/sha256"},
                "language": {"$ref": "#/$defs/language"},
                "split": {"$ref": "#/$defs/split"},
                "semantic_group_sha256": {"$ref": "#/$defs/sha256"},
                "identities": {"$ref": "#/$defs/identityLeaves"},
                "expansion": {"$ref": "#/$defs/bundleExpansion"},
                "curated_bridge_not_automatic_translation_proof": {"const": true}
            }
        },
        "independentBundle": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "schema_version",
                "record_kind",
                "track",
                "source_bundle_id",
                "task_bundle_sha256",
                "task_board_task_id",
                "language",
                "stratum",
                "semantic_profile_id",
                "template_profile_id",
                "split",
                "identities",
                "expansion",
                "cross_language_translation_pair_sha256",
                "metadata_only"
            ],
            "properties": {
                "schema_version": {
                    "const": "anchor.synthetic-scaffold-independent-confirmation-identity-record.v1"
                },
                "record_kind": {"const": "independent_confirmation_bundle"},
                "track": {"const": "producer_independent_confirmation"},
                "source_bundle_id": {
                    "type": "string",
                    "pattern": "^ic-source-v1:[0-9a-f]{64}$"
                },
                "task_bundle_sha256": {"$ref": "#/$defs/sha256"},
                "task_board_task_id": {
                    "type": "string",
                    "pattern": "^task-v2:[0-9a-f]{64}$"
                },
                "language": {"$ref": "#/$defs/language"},
                "stratum": {"$ref": "#/$defs/atom"},
                "semantic_profile_id": {"$ref": "#/$defs/atom"},
                "template_profile_id": {"$ref": "#/$defs/atom"},
                "split": {"$ref": "#/$defs/split"},
                "identities": {"$ref": "#/$defs/identityLeaves"},
                "expansion": {"$ref": "#/$defs/bundleExpansion"},
                "cross_language_translation_pair_sha256": {"type": "null"},
                "metadata_only": {"const": true}
            }
        },
        "membership": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "task_in_discovery",
                "template_in_discovery",
                "pair_in_discovery",
                "new_task_in_independent_inventory",
                "new_template_in_independent_inventory"
            ],
            "properties": {
                "task_in_discovery": {"type": "boolean"},
                "template_in_discovery": {"type": "boolean"},
                "pair_in_discovery": {"const": false},
                "new_task_in_independent_inventory": {"type": "boolean"},
                "new_template_in_independent_inventory": {"type": "boolean"}
            }
        },
        "factorialBundle": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "schema_version",
                "record_kind",
                "track",
                "source_bundle_id",
                "task_bundle_sha256",
                "task_board_task_id",
                "language",
                "stratum",
                "factor",
                "factorial_match_key_sha256",
                "split",
                "identities",
                "membership",
                "expansion",
                "metadata_only",
                "may_satisfy_independent_confirmation"
            ],
            "properties": {
                "schema_version": {
                    "const": "anchor.synthetic-scaffold-independent-confirmation-identity-record.v1"
                },
                "record_kind": {"const": "secondary_factorial_bundle"},
                "track": {"const": "secondary_controlled_factorial_probe"},
                "source_bundle_id": {
                    "type": "string",
                    "pattern": "^cf-source-v1:[0-9a-f]{64}$"
                },
                "task_bundle_sha256": {"$ref": "#/$defs/sha256"},
                "task_board_task_id": {
                    "type": "string",
                    "pattern": "^task-v2:[0-9a-f]{64}$"
                },
                "language": {"$ref": "#/$defs/language"},
                "stratum": {"$ref": "#/$defs/atom"},
                "factor": {
                    "enum": [
                        "old_task_new_template",
                        "new_task_old_template",
                        "new_task_new_template"
                    ]
                },
                "factorial_match_key_sha256": {"$ref": "#/$defs/sha256"},
                "split": {"$ref": "#/$defs/split"},
                "identities": {"$ref": "#/$defs/identityLeaves"},
                "membership": {"$ref": "#/$defs/membership"},
                "expansion": {"$ref": "#/$defs/bundleExpansion"},
                "metadata_only": {"const": true},
                "may_satisfy_independent_confirmation": {"const": false}
            }
        },
        "identityInventory": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "schema_version",
                "record_kind",
                "identity_kind",
                "identity_sha256",
                "scope_memberships"
            ],
            "properties": {
                "schema_version": {
                    "const": "anchor.synthetic-scaffold-independent-confirmation-identity-record.v1"
                },
                "record_kind": {"const": "identity_inventory_leaf"},
                "identity_kind": {
                    "enum": ["task_semantic", "template_family", "task_template_pair"]
                },
                "identity_sha256": {"$ref": "#/$defs/sha256"},
                "scope_memberships": {
                    "type": "array",
                    "minItems": 1,
                    "uniqueItems": true,
                    "items": {
                        "enum": [
                            "discovery_bridge",
                            "producer_independent_confirmation",
                            "secondary_controlled_factorial_probe"
                        ]
                    }
                }
            }
        }
    }
}
