{
  "$schema": "https://opencode.ai/config.json",
  "model": "anchor-kimi/kimi-for-coding",
  "default_agent": "anchor-distiller",
  "share": "disabled",
  "lsp": false,
  "provider": {
    "anchor-kimi": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Kimi Code (official OpenAI-compatible endpoint)",
      "options": {
        "baseURL": "https://api.kimi.com/coding/v1",
        "apiKey": "{env:KIMI_CODE_API_KEY}",
        "includeUsage": false,
        "headerTimeout": 30000,
        "chunkTimeout": 60000
      },
      "models": {
        "kimi-for-coding": {
          "name": "Kimi for Coding",
          "reasoning": true,
          "interleaved": {
            "field": "reasoning_content"
          },
          "limit": {
            "context": 262144,
            "output": 32768
          },
          "variants": {
            "medium": {
              "reasoningEffort": "medium"
            }
          }
        }
      }
    }
  },
  "permission": {
    "*": "deny",
    "read": "allow",
    "edit": "allow",
    "apply_patch": "allow",
    "write": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "external_directory": "deny",
    "task": "deny",
    "skill": "deny",
    "webfetch": "deny",
    "websearch": "deny",
    "lsp": "deny",
    "bash": {
      "*": "deny",
      "npm run build --if-present": "allow",
      "npm run test --if-present": "allow",
      "npm run lint --if-present": "allow"
    }
  },
  "agent": {
    "anchor-distiller": {
      "description": "Isolated coding task with a fail-closed tool policy",
      "mode": "primary",
      "permission": {
        "*": "deny",
        "read": "allow",
        "edit": "allow",
        "apply_patch": "allow",
        "write": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "external_directory": "deny",
        "task": "deny",
        "skill": "deny",
        "webfetch": "deny",
        "websearch": "deny",
        "lsp": "deny",
        "bash": {
          "*": "deny",
          "npm run build --if-present": "allow",
          "npm run test --if-present": "allow",
          "npm run lint --if-present": "allow"
        }
      }
    }
  }
}
