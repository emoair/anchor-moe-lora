{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anchor-moe-lora.local/schemas/tool-gold-v1.json",
  "title": "Anchor-MoE-LoRA canonical tool-validation gold record",
  "type": "object",
  "required": [
    "schema_version",
    "sample_id",
    "backend",
    "success",
    "workspace_id",
    "max_iterations",
    "timeout_seconds",
    "agent_exit_code",
    "timed_out",
    "duration_ms",
    "validations",
    "tool_trace",
    "changed_files",
    "task_bundle_sha256",
    "agent_stdout_sha256",
    "agent_stderr_sha256",
    "skill_provenance",
    "public_outcome",
    "rejected_events",
    "error_codes"
  ],
  "properties": {
    "schema_version": {"const": "anchor.tool-gold.v1"},
    "sample_id": {"type": "string", "minLength": 1},
    "backend": {"type": "string"},
    "success": {"type": "boolean"},
    "workspace_id": {"type": "string"},
    "max_iterations": {"type": ["integer", "null"], "minimum": 1},
    "timeout_seconds": {"type": "number", "exclusiveMinimum": 0},
    "agent_exit_code": {"type": "integer"},
    "timed_out": {"type": "boolean"},
    "duration_ms": {"type": "number", "minimum": 0},
    "validations": {"type": "array"},
    "tool_trace": {"type": "array"},
    "changed_files": {"type": "array"},
    "task_bundle_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "agent_stdout_sha256": {"type": ["string", "null"]},
    "agent_stderr_sha256": {"type": ["string", "null"]},
    "skill_provenance": {"type": "array"},
    "public_outcome": {
      "anyOf": [
        {"type": "null"},
        {
          "type": "object",
          "required": ["schema_version", "status", "decision_trace", "repair_summaries", "final_summary"]
        }
      ]
    },
    "rejected_events": {"type": "integer", "minimum": 0},
    "error_codes": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}
