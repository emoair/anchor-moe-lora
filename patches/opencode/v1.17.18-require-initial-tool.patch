+import { expect, test } from "bun:test"
+import { Schema } from "effect"
+import { Info } from "../../src/v1/config/agent"
+
+const decode = Schema.decodeUnknownSync(Info)
+
+test("legacy agent config keeps requireInitialToolCall out of provider options", () => {
+  const defaults = decode({})
+  expect(defaults.requireInitialToolCall).toBeUndefined()
+
+  const configured = decode({
+    requireInitialToolCall: true,
+    providerSpecificFlag: "kept",
+  })
+  expect(configured.requireInitialToolCall).toBe(true)
+  expect(configured.options).toEqual({ providerSpecificFlag: "kept" })
+})
