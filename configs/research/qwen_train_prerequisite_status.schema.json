      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "git_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:+-]{0,127}$"
    },
    "relative_path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^(?!/)(?!.*//)(?!.*(?:^|/)\\.\\.?(?:/|$))[A-Za-z0-9._-]+(?:/[A-Za-z0-9._-]+)*$"
    },
    "path_sha256": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {"$ref": "#/$defs/relative_path"},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "path_sha256_bytes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "bytes"],
