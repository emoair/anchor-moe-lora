+        tool: input?.tool ?? "read",
+        state: { status },
+        metadata: input?.providerExecuted ? { providerExecuted: true } : undefined,
+      },
+    ],
+  } as unknown as SessionV1.WithParts
+}
+
+function required(input: {
+  enabled?: boolean
+  messages?: SessionV1.WithParts[]
+  eligibleTools?: ReadonlySet<string>
+}) {
+  return shouldRequireInitialToolCall({
+    enabled: input.enabled ?? true,
+    messages: input.messages ?? [],
+    userID: currentUser,
+    agentName: "anchor-gold",
+    eligibleTools: input.eligibleTools ?? new Set(["read"]),
+  })
+}
+
+describe("shouldRequireInitialToolCall", () => {
+  test("uses exactly the versioned Anchor execution tool contract", () => {
+    expect([...INITIAL_TOOL_LOCAL_ALLOWLIST].sort()).toEqual(
+      ["read", "bash", "edit", "apply_patch", "write", "grep", "glob", "list"].sort(),
+    )
+  })
+
+  test("is off when disabled", () => {
+    expect(required({ enabled: false })).toBe(false)
+  })
+
+  test("requires the first tool when the current user turn has no tool", () => {
+    expect(required({})).toBe(true)
+  })
+
+  test("stops requiring tools after a completed tool for the current user", () => {
+    expect(required({ messages: [assistantWithTool(currentUser, "completed")] })).toBe(false)
+  })
+
+  test("does not count a completed tool belonging to another user turn", () => {
+    expect(required({ messages: [assistantWithTool(otherUser, "completed")] })).toBe(true)
+  })
+
+  test("keeps requiring after error or running tool states", () => {
+    expect(required({ messages: [assistantWithTool(currentUser, "error")] })).toBe(true)
+    expect(required({ messages: [assistantWithTool(currentUser, "running")] })).toBe(true)
+  })
+
+  test("rejects provider-executed, wrong-agent, wrong-mode, and ineligible completions", () => {
+    expect(
+      required({ messages: [assistantWithTool(currentUser, "completed", { providerExecuted: true })] }),
+    ).toBe(true)
+    expect(required({ messages: [assistantWithTool(currentUser, "completed", { agent: "build" })] })).toBe(true)
+    expect(required({ messages: [assistantWithTool(currentUser, "completed", { mode: "build" })] })).toBe(true)
+    expect(
+      required({
+        messages: [assistantWithTool(currentUser, "completed", { tool: "task" })],
+        eligibleTools: new Set(["read"]),
+      }),
+    ).toBe(true)
+  })
+
+  test("accepts only a completed eligible local tool for the current anchor turn", () => {
+    const messages = [assistantWithTool(currentUser, "completed")]
+    expect(
+      hasCompletedInitialToolCall({
+        messages,
+        userID: currentUser,
+        agentName: "anchor-gold",
+        eligibleTools: new Set(["read"]),
+      }),
+    ).toBe(true)
+  })
+})
