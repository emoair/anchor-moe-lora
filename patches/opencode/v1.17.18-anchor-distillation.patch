+function result(code = 0, stdout = "", stderr = ""): Result {
+  return { code, stdout: Buffer.from(stdout), stderr: Buffer.from(stderr) }
+}
+
+class FakeRunner implements CommandRunner {
+  readonly commands: string[][] = []
+  readonly options: (RunOptions | undefined)[] = []
+  private readonly secrets = new Set<string>()
+
+  async run(command: string[], options?: RunOptions): Promise<Result> {
+    this.commands.push(command)
+    this.options.push(options)
+    const podman = command.indexOf("podman")
+    const podmanArgs = podman === -1 ? [] : command.slice(podman + 1)
+    if (podmanArgs[0] === "secret" && podmanArgs[1] === "create") {
+      this.secrets.add(podmanArgs.at(-2)!)
+      return result()
+    }
+    if (podmanArgs[0] === "secret" && podmanArgs[1] === "ls") {
+      return result(0, [...this.secrets].join("\n") + (this.secrets.size ? "\n" : ""))
+    }
+    if (podmanArgs[0] === "secret" && podmanArgs[1] === "rm") {
+      this.secrets.delete(podmanArgs[2])
+      return result()
+    }
+    if (command.includes("wslpath")) return result(0, "/mnt/c/anchor-path\n")
+    if (command.includes("export")) return result(0, '{"info":{"id":"ses_anchor"}}\n')
+    if (command.includes("run")) return result(0, '{"type":"step_start","sessionID":"ses_anchor"}\n')
+    return result()
+  }
+}
+
+class ContainerCleanupRejectingRunner extends FakeRunner {
+  private containerRemovals = 0
+
+  override async run(command: string[], options?: RunOptions): Promise<Result> {
+    const podman = command.indexOf("podman")
+    const podmanArgs = podman === -1 ? [] : command.slice(podman + 1)
+    if (podmanArgs[0] === "rm" && podmanArgs.includes(containerName("task-cleanup-reject"))) {
+      this.containerRemovals += 1
+      if (this.containerRemovals === 2) {
+        this.commands.push(command)
+        this.options.push(options)
+        throw new Error("container cleanup spawn rejected")
+      }
+    }
+    return super.run(command, options)
+  }
+}
+
+class StaleSecretRunner extends FakeRunner {
+  override async run(command: string[], options?: RunOptions): Promise<Result> {
+    const podman = command.indexOf("podman")
+    const podmanArgs = podman === -1 ? [] : command.slice(podman + 1)
+    if (podmanArgs[0] === "secret" && podmanArgs[1] === "ls") {
+      this.commands.push(command)
+      this.options.push(options)
+      return result(0, `${secretName("task-stale")}\n`)
+    }
+    return super.run(command, options)
+  }
+}
+
+class SecretRemovalFailingRunner extends FakeRunner {
+  override async run(command: string[], options?: RunOptions): Promise<Result> {
+    const podman = command.indexOf("podman")
+    const podmanArgs = podman === -1 ? [] : command.slice(podman + 1)
+    if (podmanArgs[0] === "secret" && podmanArgs[1] === "rm") {
+      this.commands.push(command)
+      this.options.push(options)
+      return result(7, "", "secret removal failed")
+    }
+    return super.run(command, options)
+  }
+}
