index 0000000000000000000000000000000000000000..dbb5731f3d5baea6823e4e4f9dd12d2e23678601
--- /dev/null
+++ b/packages/opencode/src/anchor/sandbox.ts
@@ -0,0 +1,800 @@
+import { randomUUID } from "node:crypto"
+import { mkdir, rm } from "node:fs/promises"
+import net from "node:net"
+import path from "node:path"
+import { Process } from "@/util/process"
+import type { Child, Options, Result, RunOptions } from "@/util/process"
+
+export type AnchorHost = "windows-wsl" | "linux"
+export type AnchorSupervisor = "direct" | "wsl-root-systemd"
+
+/** Official Node 22 bookworm-slim linux/amd64 manifest digest, refreshed 2026-07-13. */
+export const DEFAULT_ANCHOR_IMAGE =
+  "docker.io/library/node@sha256:a149cd71dccd68704a07d4e4ca3e610c27301852b0f556865cfdb6e2856f8bed"
+export const ANCHOR_TOOL_CONTRACT = "anchor.execution-tool-contract.v3" as const
+export const CANONICAL_TESTBED = "/testbed" as const
+export const ANCHOR_ROUTE_SOCKET = "/run/anchor-route/ccswitch.sock" as const
+export const ANCHOR_ROUTE_HOST = "127.0.0.1" as const
+export const ANCHOR_ROUTE_PORT = 18080 as const
+export const ANCHOR_ROUTE_CLIENT_TOKEN = "anchor-local-route" as const
+
+export interface AnchorSandboxSpec {
+  workspace: string
+  config: string
+  runID: string
+  wslDistro?: string
+  image?: string
+  linuxExecutable?: string
+  memory?: string
+  cpus?: number
+  pids?: number
+  timeout?: number
+  supervisor?: AnchorSupervisor
+  routeHost?: string
+  routePort?: number
+}
+
+export interface AnchorContainerPaths {
+  workspace: string
+  config: string
+  state: string
+  route: string
+  linuxExecutable?: string
+}
+
+export interface AnchorLimits {
+  memory: string
+  cpus: number
+  pids: number
+  timeout: number
+}
+
+export interface CommandRunner {
+  run(command: string[], options?: RunOptions): Promise<Result>
+  spawn?(command: string[], options?: Options): Child
+}
+
+export class AnchorSandboxError extends Error {
+  constructor(readonly code: string) {
+    super(code)
+    this.name = "AnchorSandboxError"
+  }
+}
+
+const RUN_ID = /^[A-Za-z0-9][A-Za-z0-9_-]{0,79}$/
+const MEMORY = /^\d+(?:\.\d+)?(?:[KMGTP]i?B?|B)?$/i
+const systemRunner: CommandRunner = { run: Process.run, spawn: Process.spawn }
+
+const HOST_UNIX_ROUTE_RELAY = String.raw`
+import os,socket,sys,threading
+path,host,port=sys.argv[1],sys.argv[2],int(sys.argv[3])
+try: os.unlink(path)
+except FileNotFoundError: pass
+server=socket.socket(socket.AF_UNIX,socket.SOCK_STREAM)
+server.bind(path); os.chmod(path,0o600); server.listen(32)
+allowed={b'/anchor/health',b'/anchor/v1/models',b'/anchor/v1/responses',b'/anchor/v1/chat/completions',b'/v1/models',b'/v1/responses',b'/v1/chat/completions'}
+def pump(src,dst):
+    try:
+        while True:
+            chunk=src.recv(65536)
+            if not chunk: break
+            dst.sendall(chunk)
+    except OSError: pass
+    try: dst.shutdown(socket.SHUT_WR)
+    except OSError: pass
+def handle(client):
+    upstream=None
+    try:
+        head=b''
+        while b'\r\n\r\n' not in head and len(head)<65536:
+            chunk=client.recv(4096)
+            if not chunk: return
+            head+=chunk
+        header,sep,rest=head.partition(b'\r\n\r\n')
+        if not sep: return
+        lines=header.split(b'\r\n'); parts=lines[0].split(b' ')
+        if len(parts)!=3 or parts[0].upper()==b'CONNECT': return
+        target=parts[1]
+        if b'://' in target or b'#' in target or target.split(b'?',1)[0] not in allowed: return
+        hosts=[line.split(b':',1)[1].strip().lower() for line in lines[1:] if line.lower().startswith(b'host:')]
+        if hosts != [b'127.0.0.1:18080']: return
+        upstream=socket.create_connection((host,port),timeout=10)
+        upstream.sendall(header+sep+rest)
+        a=threading.Thread(target=pump,args=(client,upstream),daemon=True)
+        b=threading.Thread(target=pump,args=(upstream,client),daemon=True)
+        a.start(); b.start(); a.join(); b.join()
+    finally:
+        try: client.close()
+        except OSError: pass
+        if upstream is not None:
+            try: upstream.close()
+            except OSError: pass
+while True:
+    client,_=server.accept()
+    threading.Thread(target=handle,args=(client,),daemon=True).start()
+`
+
+export function validateRunID(value: string): string {
+  if (!RUN_ID.test(value)) throw new AnchorSandboxError("anchor_run_id_invalid")
+  return value
+}
+
+export function resolveAnchorHost(platform = process.platform): AnchorHost {
+  if (platform === "win32") return "windows-wsl"
+  if (platform === "linux") return "linux"
+  throw new AnchorSandboxError("anchor_host_platform_unsupported")
+}
+
+export function resolveSupervisor(value: AnchorSupervisor | undefined, host: AnchorHost): AnchorSupervisor {
+  const supervisor = value ?? (host === "windows-wsl" ? "wsl-root-systemd" : "direct")
+  if (supervisor === "wsl-root-systemd" && host !== "windows-wsl") {
+    throw new AnchorSandboxError("anchor_supervisor_host_mismatch")
+  }
+  return supervisor
+}
+
+function absolute(value: string, code: string) {
+  if (!path.isAbsolute(value)) throw new AnchorSandboxError(code)
+  return path.normalize(value)
+}
+
+function positiveInteger(value: number | undefined, fallback: number, code: string) {
+  const normalized = value ?? fallback
+  if (!Number.isSafeInteger(normalized) || normalized <= 0) throw new AnchorSandboxError(code)
+  return normalized
+}
+
+export function resolveLimits(input: Pick<AnchorSandboxSpec, "memory" | "cpus" | "pids" | "timeout">): AnchorLimits {
+  const memory = input.memory ?? "4G"
+  if (!MEMORY.test(memory)) throw new AnchorSandboxError("anchor_memory_invalid")
+  const cpus = input.cpus ?? 2
+  if (!Number.isFinite(cpus) || cpus <= 0) throw new AnchorSandboxError("anchor_cpus_invalid")
+  return {
+    memory,
+    cpus,
+    pids: positiveInteger(input.pids, 256, "anchor_pids_invalid"),
+    timeout: positiveInteger(input.timeout, 900, "anchor_timeout_invalid"),
+  }
+}
+
+export function resolveSandboxPaths(input: Pick<AnchorSandboxSpec, "workspace" | "config" | "runID">) {
+  const workspace = absolute(input.workspace, "anchor_workspace_not_absolute")
+  const config = absolute(input.config, "anchor_config_not_absolute")
+  const runID = validateRunID(input.runID)
+  return {
+    workspace,
+    config,
+    state: path.join(workspace, ".anchor", "sandbox", runID),
+    runID,
+  }
+}
+
+export function resolveImage(input: Pick<AnchorSandboxSpec, "image">, environment: NodeJS.ProcessEnv = process.env) {
+  const image = input.image ?? environment.ANCHOR_PODMAN_IMAGE ?? DEFAULT_ANCHOR_IMAGE
+  if (!image.trim()) throw new AnchorSandboxError("anchor_image_missing")
+  return image
+}
+
+export function validateLocalRouteTarget(host: string | undefined, port: number | undefined) {
+  const target = host ?? ANCHOR_ROUTE_HOST
+  const octets = target.split(".").map(Number)
+  const privateAddress =
+    octets.length === 4 &&
+    octets.every((value) => Number.isInteger(value) && value >= 0 && value <= 255) &&
+    (octets[0] === 127 ||
+      octets[0] === 10 ||
+      (octets[0] === 172 && octets[1] >= 16 && octets[1] <= 31) ||
+      (octets[0] === 192 && octets[1] === 168))
+  if (!privateAddress) throw new AnchorSandboxError("anchor_route_host_not_local")
+  const targetPort = port ?? ANCHOR_ROUTE_PORT
+  if (!Number.isSafeInteger(targetPort) || targetPort < 1 || targetPort > 65535) {
+    throw new AnchorSandboxError("anchor_route_port_invalid")
+  }
+  return { host: target, port: targetPort }
+}
+
+export function routeUnitName(runID: string) {
+  return `anchor-route-${validateRunID(runID)}`
+}
+
+export function resolveRouteDirectory(runID: string, host: AnchorHost, environment: NodeJS.ProcessEnv = process.env) {
+  const safe = validateRunID(runID)
+  if (host === "windows-wsl") return `/run/anchor-opencode/${safe}`
+  const runtime = environment.XDG_RUNTIME_DIR
+  if (runtime?.startsWith("/")) return path.posix.join(runtime, "anchor-opencode", safe)
+  const uid = typeof process.getuid === "function" ? process.getuid() : 65534
+  return `/tmp/anchor-opencode-${uid}/${safe}`
+}
+
+export function scrubHostEnvironment(input: NodeJS.ProcessEnv = process.env): NodeJS.ProcessEnv {
+  const blocked = new Set([
+    "KIMI_CODE_API_KEY",
+    "OPENCODE_CONFIG_CONTENT",
+    "CONTAINER_HOST",
+    "DOCKER_HOST",
+    "PODMAN_HOST",
+    "WSLENV",
+  ])
+  const credential = /(?:API_?KEY|TOKEN|SECRET|PASSWORD|CREDENTIAL)/i
+  return Object.fromEntries(
+    Object.entries(input).filter(([key]) => !blocked.has(key.toUpperCase()) && !credential.test(key)),
+  )
+}
+
+export function containerName(runID: string) {
+  return `anchor-${validateRunID(runID)}`
+}
+
+export function systemdUnitName(runID: string, nonce = randomUUID()) {
+  return `anchor-${validateRunID(runID)}-${nonce.replaceAll("-", "")}`.slice(0, 120)
+}
+
+export function buildHostExecCommand(input: { host: AnchorHost; distro?: string; root?: boolean; command: string[] }) {
+  if (input.host === "linux") return input.command
+  if (!input.distro?.trim()) throw new AnchorSandboxError("anchor_wsl_distro_missing")
+  return [
+    "wsl.exe",
+    "--distribution",
+    input.distro,
+    ...(input.root ? ["--user", "root"] : []),
+    "--exec",
+    ...input.command,
+  ]
+}
+
+export function buildPodmanCommand(input: {
+  host: AnchorHost
+  distro?: string
+  supervisor: AnchorSupervisor
+  operation: "run" | "manage"
+  podmanArgs: string[]
+  limits: AnchorLimits
+  unit?: string
+}) {
+  if (input.host === "linux") return ["podman", ...input.podmanArgs]
+  if (input.supervisor === "direct") {
+    return buildHostExecCommand({ host: input.host, distro: input.distro, command: ["podman", ...input.podmanArgs] })
+  }
+  if (input.operation === "manage") {
+    return buildHostExecCommand({
+      host: input.host,
+      distro: input.distro,
+      root: true,
+      command: ["podman", ...input.podmanArgs],
+    })
+  }
+  const unit = input.unit ?? systemdUnitName("anchor")
+  return buildHostExecCommand({
+    host: input.host,
+    distro: input.distro,
+    root: true,
+    command: [
+      "systemd-run",
+      "--quiet",
+      "--wait",
+      "--collect",
+      "--pipe",
+      `--unit=${unit}`,
+      "-p",
+      `MemoryMax=${input.limits.memory}`,
+      "-p",
+      `CPUQuota=${input.limits.cpus * 100}%`,
+      "-p",
+      `TasksMax=${input.limits.pids}`,
+      "-p",
+      `RuntimeMaxSec=${input.limits.timeout}s`,
+      "--",
+      "podman",
+      ...input.podmanArgs,
+    ],
+  })
+}
+
+function containerBaseArgs(input: {
+  runID: string
+  paths: AnchorContainerPaths
+  limits: AnchorLimits
+  rootful: boolean
+}) {
+  const args = [
+    "run",
+    "--rm",
+    "--name",
+    containerName(input.runID),
+    "--cap-drop=ALL",
+    "--security-opt=no-new-privileges",
+    "--read-only",
+    "--tmpfs",
+    "/tmp:rw,noexec,nosuid,size=256m",
+    "--network",
+    "none",
+    "--workdir",
+    CANONICAL_TESTBED,
+    "--mount",
+    `type=bind,src=${input.paths.workspace},dst=${CANONICAL_TESTBED},rw`,
+    "--mount",
+    `type=bind,src=${input.paths.state},dst=/anchor/state,rw`,
+    "--mount",
+    `type=bind,src=${input.paths.config},dst=/anchor/config/opencode.json,ro`,
+    "--mount",
+    `type=bind,src=${input.paths.route},dst=/run/anchor-route,ro`,
+    "--env",
+    "OPENCODE_CONFIG=/anchor/config/opencode.json",
+    "--env",
+    "OPENCODE_CONFIG_DIR=/anchor/state/config",
+    "--env",
+    "OPENCODE_DISABLE_PROJECT_CONFIG=true",
+    "--env",
+    "OPENCODE_DISABLE_DEFAULT_PLUGINS=true",
+    "--env",
+    "OPENCODE_DISABLE_LSP_DOWNLOAD=true",
+    "--env",
+    "OPENCODE_DISABLE_MODELS_FETCH=true",
+    "--env",
+    "OPENCODE_AUTO_SHARE=false",
+    "--env",
+    `ANCHOR_LOCAL_ROUTE_CLIENT_TOKEN=${ANCHOR_ROUTE_CLIENT_TOKEN}`,
+    "--env",
+    "HOME=/anchor/state/home",
+    "--env",
+    "XDG_CONFIG_HOME=/anchor/state/config",
+    "--env",
+    "XDG_DATA_HOME=/anchor/state/data",
+    "--env",
+    "XDG_CACHE_HOME=/anchor/state/cache",
+  ]
+  if (input.rootful) {
+    // WSL's older rootful Podman cannot set the requested resource flags with cgroups enabled.
+    args.push("--cgroups=disabled")
+  } else {
+    args.push(
+      "--userns=keep-id",
+      "--memory",
+      input.limits.memory,
+      "--cpus",
+      String(input.limits.cpus),
+      "--pids-limit",
+      String(input.limits.pids),
+    )
+  }
+  if (input.paths.linuxExecutable) {
+    args.push("--mount", `type=bind,src=${input.paths.linuxExecutable},dst=/anchor/bin/opencode,ro`)
+  }
+  return args
+}
+
+export function buildContainerRunArgs(input: {
+  image: string
+  runID: string
+  paths: AnchorContainerPaths
+  limits: AnchorLimits
+  rootful: boolean
+  opencodeArgs: string[]
+}) {
+  const executable = input.paths.linuxExecutable ? "/anchor/bin/opencode" : "opencode"
+  return [
+    ...containerBaseArgs(input),
+    "--entrypoint",
+    "/bin/sh",
+    input.image,
+    "-c",
+    'bridge="$1"; shift; "$bridge" anchor _route-bridge & bridge_pid=$!; sleep 1; kill -0 "$bridge_pid"; exec "$@"',
+    "anchor-entrypoint",
+    executable,
+    executable,
+    ...input.opencodeArgs,
+  ]
+}
+
+export function buildContainerExportArgs(input: {
+  image: string
+  runID: string
+  paths: AnchorContainerPaths
+  limits: AnchorLimits
+  rootful: boolean
+  sessionID: string
+}) {
+  const executable = input.paths.linuxExecutable ? "/anchor/bin/opencode" : "opencode"
+  const base = containerBaseArgs(input)
+  const routeMount = `type=bind,src=${input.paths.route},dst=/run/anchor-route,ro`
+  const index = base.indexOf(routeMount)
+  if (index !== -1) base.splice(index - 1, 2)
+  const token = `ANCHOR_LOCAL_ROUTE_CLIENT_TOKEN=${ANCHOR_ROUTE_CLIENT_TOKEN}`
+  const tokenIndex = base.indexOf(token)
+  if (tokenIndex !== -1) base.splice(tokenIndex - 1, 2)
+  return [...base, "--entrypoint", executable, input.image, "export", input.sessionID]
+}
+
+async function toWslPath(
+  runner: CommandRunner,
+  distro: string | undefined,
+  hostPath: string,
+  environment: NodeJS.ProcessEnv,
+) {
+  const result = await runner.run(
+    buildHostExecCommand({
+      host: "windows-wsl",
+      distro,
+      command: ["wslpath", "-a", "-u", hostPath],
+    }),
+    { env: environment, envMode: "replace", nothrow: true },
+  )
+  const converted = result.stdout.toString().trim()
+  if (result.code !== 0 || !converted) throw new AnchorSandboxError("anchor_wslpath_failed")
+  return converted
+}
+
+async function resolveContainerPaths(input: {
+  spec: AnchorSandboxSpec
+  host: AnchorHost
+  runner: CommandRunner
+  environment: NodeJS.ProcessEnv
+}) {
+  const local = resolveSandboxPaths(input.spec)
+  const linuxExecutable = input.spec.linuxExecutable
+    ? absolute(input.spec.linuxExecutable, "anchor_linux_executable_not_absolute")
+    : undefined
+  const route = resolveRouteDirectory(input.spec.runID, input.host, input.environment)
+  await mkdir(local.state, { recursive: true })
+  if (input.host === "linux") {
+    return {
+      local,
+      container: { ...local, route, linuxExecutable } satisfies AnchorContainerPaths,
+    }
+  }
+  const converted = await Promise.all([
+    toWslPath(input.runner, input.spec.wslDistro, local.workspace, input.environment),
+    toWslPath(input.runner, input.spec.wslDistro, local.config, input.environment),
+    toWslPath(input.runner, input.spec.wslDistro, local.state, input.environment),
+    linuxExecutable
+      ? toWslPath(input.runner, input.spec.wslDistro, linuxExecutable, input.environment)
+      : Promise.resolve(undefined),
+  ])
+  return {
+    local,
+    container: {
+      workspace: converted[0],
+      config: converted[1],
+      state: converted[2],
+      route,
+      linuxExecutable: converted[3],
+    } satisfies AnchorContainerPaths,
+  }
+}
+
+async function removeContainer(input: {
+  spec: Pick<AnchorSandboxSpec, "runID" | "wslDistro" | "supervisor">
+  host: AnchorHost
+  supervisor: AnchorSupervisor
+  limits: AnchorLimits
+  runner: CommandRunner
+  environment: NodeJS.ProcessEnv
+}) {
+  const result = await input.runner.run(
+    buildPodmanCommand({
+      host: input.host,
+      distro: input.spec.wslDistro,
+      supervisor: input.supervisor,
+      operation: "manage",
+      podmanArgs: ["rm", "--force", "--ignore", containerName(input.spec.runID)],
+      limits: input.limits,
+    }),
+    { env: input.environment, envMode: "replace", nothrow: true },
+  )
+  if (result.code !== 0) throw new AnchorSandboxError("anchor_container_remove_failed")
+}
+
+interface RouteRelay {
+  directory: string
+  socket: string
+  unit?: string
+  child?: Child
+}
+
+function routeCommand(input: { host: AnchorHost; distro?: string; root?: boolean; command: string[] }) {
+  return buildHostExecCommand(input)
+}
+
+async function stopRouteRelay(
+  input: {
+    spec: Pick<AnchorSandboxSpec, "runID" | "wslDistro">
+    host: AnchorHost
+    runner: CommandRunner
+    environment: NodeJS.ProcessEnv
+  },
+  relay?: RouteRelay,
+) {
+  const directory = relay?.directory ?? resolveRouteDirectory(input.spec.runID, input.host, input.environment)
+  if (relay?.child && relay.child.exitCode === null && relay.child.signalCode === null) {
+    relay.child.kill("SIGTERM")
+    await relay.child.exited.catch(() => 1)
+  }
+  if (input.host === "windows-wsl") {
+    await input.runner.run(
+      routeCommand({
+        host: input.host,
+        distro: input.spec.wslDistro,
+        root: true,
+        command: ["systemctl", "stop", relay?.unit ?? routeUnitName(input.spec.runID)],
+      }),
+      { env: input.environment, envMode: "replace", nothrow: true },
+    )
+  }
+  const removed = await input.runner.run(
+    routeCommand({
+      host: input.host,
+      distro: input.spec.wslDistro,
+      root: input.host === "windows-wsl",
+      command: ["rm", "-rf", "--", directory],
+    }),
+    { env: input.environment, envMode: "replace", nothrow: true },
+  )
+  if (removed.code !== 0) throw new AnchorSandboxError("anchor_route_socket_remove_failed")
+}
+
+async function startRouteRelay(input: {
+  spec: AnchorSandboxSpec
+  host: AnchorHost
+  runner: CommandRunner
+  environment: NodeJS.ProcessEnv
+  limits: AnchorLimits
+}): Promise<RouteRelay> {
+  const target = validateLocalRouteTarget(input.spec.routeHost, input.spec.routePort)
+  const directory = resolveRouteDirectory(input.spec.runID, input.host, input.environment)
+  const socket = path.posix.join(directory, "ccswitch.sock")
+  const unit = routeUnitName(input.spec.runID)
+  const prepared = await input.runner.run(
+    routeCommand({
+      host: input.host,
+      distro: input.spec.wslDistro,
+      root: input.host === "windows-wsl",
+      command: ["install", "-d", "-m", "700", directory],
+    }),
+    { env: input.environment, envMode: "replace", nothrow: true },
+  )
+  if (prepared.code !== 0) throw new AnchorSandboxError("anchor_route_socket_stage_failed")
+
+  let child: Child | undefined
+  if (input.host === "windows-wsl") {
+    const started = await input.runner.run(
+      routeCommand({
+        host: input.host,
+        distro: input.spec.wslDistro,
+        root: true,
+        command: [
+          "systemd-run",
+          "--quiet",
+          "--collect",
+          `--unit=${unit}`,
+          "-p",
+          `RuntimeMaxSec=${input.limits.timeout + 120}s`,
+          "--",
+          "python3",
+          "-c",
+          HOST_UNIX_ROUTE_RELAY,
+          socket,
+          target.host,
+          String(target.port),
+        ],
+      }),
+      { env: input.environment, envMode: "replace", nothrow: true },
+    )
+    if (started.code !== 0) throw new AnchorSandboxError("anchor_route_socket_start_failed")
+  } else {
+    if (!input.runner.spawn) throw new AnchorSandboxError("anchor_route_spawn_unavailable")
+    child = input.runner.spawn(["python3", "-c", HOST_UNIX_ROUTE_RELAY, socket, target.host, String(target.port)], {
+      env: input.environment,
+      envMode: "replace",
+    })
+  }
+
+  for (let attempt = 0; attempt < 50; attempt++) {
+    const ready = await input.runner.run(
+      routeCommand({
+        host: input.host,
+        distro: input.spec.wslDistro,
+        root: input.host === "windows-wsl",
+        command: ["test", "-S", socket],
+      }),
+      { env: input.environment, envMode: "replace", nothrow: true },
+    )
+    if (ready.code === 0) return { directory, socket, unit: input.host === "windows-wsl" ? unit : undefined, child }
+    if (child && child.exitCode !== null) break
+    await new Promise((resolve) => setTimeout(resolve, 20))
+  }
+  await stopRouteRelay(input, { directory, socket, unit, child })
+  throw new AnchorSandboxError("anchor_route_socket_start_failed")
+}
+
+export function runContainerRouteBridge(
+  socketPath: string = ANCHOR_ROUTE_SOCKET,
+  port: number = ANCHOR_ROUTE_PORT,
+): Promise<never> {
+  if (socketPath !== ANCHOR_ROUTE_SOCKET || port !== ANCHOR_ROUTE_PORT) {
+    throw new AnchorSandboxError("anchor_route_bridge_target_invalid")
+  }
+  return new Promise((_, reject) => {
+    const server = net.createServer((client) => {
+      const upstream = net.createConnection({ path: socketPath })
+      client.pipe(upstream)
+      upstream.pipe(client)
+      const close = () => {
+        client.destroy()
+        upstream.destroy()
+      }
+      client.once("error", close)
+      upstream.once("error", close)
+    })
+    server.once("error", reject)
+    server.listen({ host: ANCHOR_ROUTE_HOST, port, exclusive: true })
+  })
+}
+
+async function cleanupRuntimeResources(
+  input: {
+    spec: Pick<AnchorSandboxSpec, "runID" | "wslDistro" | "supervisor">
+    host: AnchorHost
+    supervisor: AnchorSupervisor
+    limits: AnchorLimits
+    runner: CommandRunner
+    environment: NodeJS.ProcessEnv
+  },
+  relay?: RouteRelay,
+) {
+  const errors: unknown[] = []
+  try {
+    await removeContainer(input)
+  } catch (error) {
+    errors.push(error)
+  }
+  try {
+    await stopRouteRelay(input, relay)
+  } catch (error) {
+    errors.push(error)
+  }
+  if (errors.length === 1) throw errors[0]
+  if (errors.length > 1) throw new AggregateError(errors, "anchor_runtime_cleanup_failed")
+}
+
+async function withHostTimeout<T>(timeout: number, fn: (abort: AbortSignal) => Promise<T>) {
+  const controller = new AbortController()
+  const timer = setTimeout(() => controller.abort(), timeout * 1000)
+  try {
+    return await fn(controller.signal)
+  } finally {
+    clearTimeout(timer)
+  }
+}
+
+export async function runSandboxed(
+  spec: AnchorSandboxSpec,
+  opencodeArgs: string[],
+  options: { runner?: CommandRunner; platform?: NodeJS.Platform } = {},
+) {
+  const runner = options.runner ?? systemRunner
+  const host = resolveAnchorHost(options.platform)
+  const supervisor = resolveSupervisor(spec.supervisor, host)
+  const rootful = host === "windows-wsl" && supervisor === "wsl-root-systemd"
+  const environment = scrubHostEnvironment()
+  const limits = resolveLimits(spec)
+  const cleanup = { spec, host, supervisor, limits, runner, environment }
+  let relay: RouteRelay | undefined
+  let operationFailed = false
+  let operationError: unknown
+  try {
+    // A deterministic name allows recovery after a crash before starting a new task with this run id.
+    await cleanupRuntimeResources(cleanup)
+    const paths = await resolveContainerPaths({ spec, host, runner, environment })
+    const image = resolveImage(spec)
+    relay = await startRouteRelay({ spec, host, runner, environment, limits })
+    return await withHostTimeout(limits.timeout, (abort) =>
+      runner.run(
+        buildPodmanCommand({
+          host,
+          distro: spec.wslDistro,
+          supervisor,
+          operation: "run",
+          podmanArgs: buildContainerRunArgs({
+            image,
+            runID: spec.runID,
+            paths: paths.container,
+            limits,
+            rootful,
+            opencodeArgs,
+          }),
+          limits,
+          unit: systemdUnitName(spec.runID),
+        }),
+        { env: environment, envMode: "replace", abort, timeout: 5_000, nothrow: true },
+      ),
+    )
+  } catch (error) {
+    operationFailed = true
+    operationError = error
+    throw error
+  } finally {
+    try {
+      await cleanupRuntimeResources(cleanup, relay)
+    } catch (cleanupError) {
+      if (operationFailed) {
+        throw new AggregateError([operationError, cleanupError], "anchor_run_and_cleanup_failed")
+      }
+      throw cleanupError
+    }
+  }
+}
+
+export async function exportSandboxed(
+  spec: AnchorSandboxSpec,
+  sessionID: string,
+  options: { runner?: CommandRunner; platform?: NodeJS.Platform } = {},
+) {
+  const runner = options.runner ?? systemRunner
+  const host = resolveAnchorHost(options.platform)
+  const supervisor = resolveSupervisor(spec.supervisor, host)
+  const rootful = host === "windows-wsl" && supervisor === "wsl-root-systemd"
+  const environment = scrubHostEnvironment()
+  const limits = resolveLimits(spec)
+  const cleanup = { spec, host, supervisor, limits, runner, environment }
+  await cleanupRuntimeResources(cleanup)
+  const paths = await resolveContainerPaths({ spec, host, runner, environment })
+  const image = resolveImage(spec)
+  try {
+    return await withHostTimeout(limits.timeout, (abort) =>
+      runner.run(
+        buildPodmanCommand({
+          host,
+          distro: spec.wslDistro,
+          supervisor,
+          operation: "run",
+          podmanArgs: buildContainerExportArgs({
+            image,
+            runID: spec.runID,
+            paths: paths.container,
+            limits,
+            rootful,
+            sessionID,
+          }),
+          limits,
+          unit: systemdUnitName(spec.runID),
+        }),
+        { env: environment, envMode: "replace", abort, timeout: 5_000, nothrow: true },
+      ),
+    )
+  } finally {
+    await cleanupRuntimeResources(cleanup)
+  }
+}
+
+export async function cleanupSandboxed(
+  input: Pick<AnchorSandboxSpec, "workspace" | "runID" | "wslDistro" | "supervisor">,
+  options: { runner?: CommandRunner; platform?: NodeJS.Platform } = {},
+) {
+  const workspace = absolute(input.workspace, "anchor_workspace_not_absolute")
+  const state = path.join(workspace, ".anchor", "sandbox", validateRunID(input.runID))
+  const runner = options.runner ?? systemRunner
+  const host = resolveAnchorHost(options.platform)
+  const supervisor = resolveSupervisor(input.supervisor, host)
+  const environment = scrubHostEnvironment()
+  const limits = resolveLimits({})
+  const errors: unknown[] = []
+  try {
+    await cleanupRuntimeResources({
+      spec: input,
+      host,
+      supervisor,
+      limits,
+      runner,
+      environment,
+    })
+  } catch (error) {
+    errors.push(error)
+  }
+  try {
+    await rm(state, { recursive: true, force: true })
+  } catch (error) {
+    errors.push(error)
+  }
+  if (errors.length === 1) throw errors[0]
+  if (errors.length > 1) throw new AggregateError(errors, "anchor_cleanup_failed")
+}
