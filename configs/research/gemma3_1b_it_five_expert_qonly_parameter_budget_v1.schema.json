        "five_expert_bf16_checkpoint_bytes": {"type": "integer", "minimum": 1},
        "single_active_training_state_16bpp_bytes": {
          "type": "integer",
          "minimum": 1
        },
        "all_experts_training_state_16bpp_bytes": {
          "type": "integer",
          "minimum": 1
        },
        "rough_peak_active_only_bytes": {"type": "integer", "minimum": 1},
        "rough_peak_sequential_all_checkpoints_resident_bytes": {
          "type": "integer",
          "minimum": 1
